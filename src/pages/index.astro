---
// baseballab.com — top page
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Baseballab | 野球データを、もっと深く。"
  description="MLB・NPBの統計データをデータドリブンな視点で分析。選手成績比較、チーム別データ、セイバーメトリクス解説まで、野球ファン・指導者・分析者のための情報サイト。"
  ogUrl="https://baseballab.com"
>
  <style slot="head">
    /* ===== HERO ===== */
    .hero {
      background: linear-gradient(135deg, var(--navy-dark) 0%, var(--navy) 60%, var(--navy-light) 100%);
      color: var(--white);
      padding: 5rem 1.25rem 4rem;
      text-align: center;
      position: relative;
      overflow: hidden;
    }

    .hero::before {
      content: '⚾';
      position: absolute;
      font-size: 22rem;
      opacity: 0.04;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      pointer-events: none;
      line-height: 1;
    }

    .hero-eyebrow {
      display: inline-block;
      background: rgba(192, 57, 43, 0.85);
      color: var(--white);
      font-size: 0.78rem;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      padding: 0.3rem 0.9rem;
      border-radius: 9999px;
      margin-bottom: 1.25rem;
    }

    .hero h1 {
      font-size: clamp(2rem, 5vw, 3.25rem);
      font-weight: 900;
      letter-spacing: -0.03em;
      line-height: 1.2;
      margin-bottom: 1.25rem;
    }
    .hero h1 em { color: #7ec8e3; font-style: normal; }

    .hero-sub {
      font-size: clamp(0.95rem, 2vw, 1.15rem);
      color: rgba(255,255,255,0.8);
      max-width: 600px;
      margin: 0 auto 2.25rem;
      line-height: 1.75;
    }

    .hero-cta {
      display: flex;
      justify-content: center;
      gap: 1rem;
      flex-wrap: wrap;
    }

    .btn {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      padding: 0.8rem 1.8rem;
      border-radius: 6px;
      font-weight: 700;
      font-size: 0.95rem;
      cursor: pointer;
      transition: transform 0.15s, box-shadow 0.15s;
    }
    .btn:hover { transform: translateY(-2px); box-shadow: 0 6px 16px rgba(0,0,0,0.25); }

    .btn-primary {
      background: var(--red);
      color: var(--white);
    }
    .btn-primary:hover { background: var(--red-hover); }

    .btn-outline {
      border: 2px solid rgba(255,255,255,0.6);
      color: var(--white);
      background: transparent;
    }
    .btn-outline:hover { border-color: var(--white); background: rgba(255,255,255,0.1); }

    /* ===== SECTION COMMON ===== */
    .section {
      padding: 4rem 0;
    }
    .section-alt {
      background: var(--gray-100);
    }

    .section-header {
      text-align: center;
      margin-bottom: 2.5rem;
    }
    .section-label {
      display: inline-block;
      color: var(--red);
      font-size: 0.78rem;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      margin-bottom: 0.5rem;
    }
    .section-title {
      font-size: clamp(1.4rem, 3vw, 1.85rem);
      font-weight: 800;
      color: var(--navy);
      letter-spacing: -0.02em;
    }
    .section-lead {
      margin-top: 0.6rem;
      color: var(--gray-600);
      font-size: 0.95rem;
    }

    /* ===== FEATURE CARDS ===== */
    .card-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      gap: 1.5rem;
    }

    .feature-card {
      background: var(--white);
      border: 1px solid var(--gray-200);
      border-radius: 12px;
      padding: 1.75rem 1.5rem;
      transition: box-shadow 0.2s, transform 0.2s;
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
    }
    .feature-card:hover {
      box-shadow: 0 8px 24px rgba(26,58,92,0.12);
      transform: translateY(-3px);
    }

    .card-icon {
      font-size: 2rem;
      line-height: 1;
    }

    .card-title {
      font-size: 1.05rem;
      font-weight: 700;
      color: var(--navy);
    }

    .card-desc {
      font-size: 0.88rem;
      color: var(--gray-600);
      line-height: 1.65;
      flex: 1;
    }

    .card-link {
      display: inline-flex;
      align-items: center;
      gap: 0.3rem;
      color: var(--red);
      font-size: 0.85rem;
      font-weight: 600;
      margin-top: 0.25rem;
      transition: gap 0.15s;
    }
    .card-link:hover { gap: 0.55rem; }

    .card-league-badge {
      display: inline-block;
      font-size: 0.68rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      padding: 0.15rem 0.6rem;
      border-radius: 9999px;
      color: var(--white);
      width: fit-content;
    }
    .card-league-badge.mlb { background: #1a3a5c; }
    .card-league-badge.npb { background: #9b2335; }

    /* ===== ARTICLES ===== */
    .article-list {
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    .article-item {
      background: var(--white);
      border: 1px solid var(--gray-200);
      border-radius: 10px;
      padding: 1.1rem 1.4rem;
      display: flex;
      align-items: center;
      gap: 1rem;
      transition: box-shadow 0.2s;
    }
    .article-item:hover {
      box-shadow: 0 4px 16px rgba(26,58,92,0.1);
    }

    .article-rank {
      flex-shrink: 0;
      width: 2rem;
      height: 2rem;
      background: var(--navy);
      color: var(--white);
      border-radius: 50%;
      font-weight: 800;
      font-size: 0.85rem;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .article-rank.gold { background: #c9a227; }
    .article-rank.silver { background: #8c9496; }
    .article-rank.bronze { background: #a0522d; }

    .article-body {
      flex: 1;
      min-width: 0;
    }
    .article-tag {
      font-size: 0.72rem;
      font-weight: 700;
      color: var(--red);
      letter-spacing: 0.06em;
      text-transform: uppercase;
      margin-bottom: 0.2rem;
    }
    .article-title {
      font-size: 0.95rem;
      font-weight: 600;
      color: var(--navy-dark);
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .article-meta {
      font-size: 0.78rem;
      color: var(--gray-400);
      margin-top: 0.2rem;
    }

    .article-arrow {
      flex-shrink: 0;
      color: var(--gray-400);
      font-size: 1.1rem;
      transition: color 0.15s, transform 0.15s;
    }
    .article-item:hover .article-arrow {
      color: var(--red);
      transform: translateX(3px);
    }

    /* ===== AFFILIATE BANNER ===== */
    .affiliate-section {
      background: var(--navy-dark);
      color: var(--white);
      padding: 3.5rem 0;
    }

    .affiliate-label {
      display: inline-block;
      background: rgba(255,255,255,0.15);
      color: rgba(255,255,255,0.7);
      font-size: 0.7rem;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      padding: 0.2rem 0.65rem;
      border-radius: 4px;
      margin-bottom: 1rem;
      border: 1px solid rgba(255,255,255,0.2);
    }

    .affiliate-section .section-title {
      color: var(--white);
      text-align: center;
      margin-bottom: 0.5rem;
    }
    .affiliate-section .section-lead {
      color: rgba(255,255,255,0.6);
      text-align: center;
      margin-bottom: 2rem;
    }

    .affiliate-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
      gap: 1.25rem;
    }

    .affiliate-card {
      background: rgba(255,255,255,0.07);
      border: 1px solid rgba(255,255,255,0.12);
      border-radius: 10px;
      padding: 1.5rem;
      display: flex;
      gap: 1rem;
      align-items: flex-start;
      transition: background 0.2s;
      text-decoration: none;
      color: inherit;
    }
    .affiliate-card:hover {
      background: rgba(255,255,255,0.12);
    }

    .affiliate-thumb {
      flex-shrink: 0;
      width: 90px;
      min-height: 120px;
      background: rgba(255,255,255,0.1);
      border-radius: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
      position: relative;
    }
    .affiliate-thumb img {
      width: 100%;
      height: 100%;
      object-fit: contain;
      padding: 0.35rem;
    }
    .aff-icon-fallback {
      font-size: 2.5rem;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .affiliate-info {
      flex: 1;
      min-width: 0;
    }
    .affiliate-info .badge-sponsor {
      font-size: 0.68rem;
      color: rgba(255,255,255,0.5);
      letter-spacing: 0.08em;
      text-transform: uppercase;
      margin-bottom: 0.3rem;
    }
    .affiliate-info h3 {
      font-size: 0.9rem;
      font-weight: 700;
      color: var(--white);
      margin-bottom: 0.35rem;
    }
    .affiliate-info p {
      font-size: 0.8rem;
      color: rgba(255,255,255,0.6);
      line-height: 1.5;
    }
    .affiliate-info .affiliate-cta {
      display: inline-block;
      margin-top: 0.6rem;
      font-size: 0.75rem;
      font-weight: 700;
      background: #FF9900;
      color: #111;
      padding: 0.25rem 0.7rem;
      border-radius: 4px;
    }
    .affiliate-disclosure {
      font-size: 0.72rem;
      color: rgba(255,255,255,0.45);
      margin-top: 1.25rem;
      text-align: center;
    }
    .affiliate-disclosure a { color: rgba(255,255,255,0.55); text-decoration: underline; }

    /* ===== RESPONSIVE ===== */
    @media (max-width: 768px) {
      .hero { padding: 3.5rem 1.25rem 3rem; }
      .hero::before { font-size: 14rem; }
      .section { padding: 3rem 0; }
      .article-title { font-size: 0.88rem; }
    }
  </style>

  <!-- ===== HERO ===== -->
  <section class="hero">
    <div class="container">
      <p class="hero-eyebrow">⚾ Baseball Data Analysis</p>
      <h1>野球データを、<br><em>もっと深く。</em></h1>
      <p class="hero-sub">
        MLB・NPBの統計データをデータドリブンな独自視点で分析。<br>
        セイバーメトリクスから選手比較まで、野球ファン・指導者・アナリストのための情報ラボ。
      </p>
      <div class="hero-cta">
        <a href="/mlb/" class="btn btn-primary">🇺🇸 MLB データ分析</a>
        <a href="/npb/" class="btn btn-primary" style="background:#9b2335">🇯🇵 NPB データ分析</a>
        <a href="/glossary/" class="btn btn-outline">📖 指標解説</a>
      </div>
    </div>
  </section>

  <!-- ===== FEATURE CARDS ===== -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <p class="section-label">Features</p>
        <h2 class="section-title">Baseballabでできること</h2>
        <p class="section-lead">MLB・NPBのデータを多角的に分析・比較。あなたの野球観戦・指導を深める情報を提供します。</p>
      </div>
      <div class="card-grid">
        <!-- カード1: MLB データ分析 -->
        <div class="feature-card">
          <span class="card-league-badge mlb">🇺🇸 MLB</span>
          <div class="card-icon">📊</div>
          <h3 class="card-title">MLB データ分析</h3>
          <p class="card-desc">
            全30球団・選手の打撃・投球・守備成績を網羅。WAR・OPS・FIPなどセイバーメトリクス指標で大谷翔平ほか注目選手を分析。
          </p>
          <a href="/mlb/" class="card-link">MLBを見る →</a>
        </div>
        <!-- カード2: NPB データ分析 -->
        <div class="feature-card">
          <span class="card-league-badge npb">🇯🇵 NPB</span>
          <div class="card-icon">⚾</div>
          <h3 class="card-title">NPB データ分析</h3>
          <p class="card-desc">
            セ・パ12球団の順位表・選手成績を随時更新。打率・防御率・OPSなど主要指標で日本プロ野球を数値で読み解く。
          </p>
          <a href="/npb/" class="card-link">NPBを見る →</a>
        </div>
        <!-- カード3: 試合結果・トレンド -->
        <div class="feature-card">
          <div class="card-icon">📈</div>
          <h3 class="card-title">試合結果・トレンド</h3>
          <p class="card-desc">
            直近の試合結果と成績トレンドを時系列で追う。ホットストリーク・スランプの可視化で観戦をより深く楽しめます。
          </p>
          <a href="/season/" class="card-link">詳細を見る →</a>
        </div>
        <!-- カード4: セイバーメトリクス解説 -->
        <div class="feature-card">
          <div class="card-icon">📚</div>
          <h3 class="card-title">指標・セイバーメトリクス解説</h3>
          <p class="card-desc">
            WARとは？FIPとは？難解な野球指標をやさしく丁寧に解説。初心者から上級者まで使える用語集を整備しています。
          </p>
          <a href="/glossary/" class="card-link">詳細を見る →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== POPULAR ARTICLES ===== -->
  <section class="section section-alt">
    <div class="container">
      <div class="section-header">
        <p class="section-label">Popular</p>
        <h2 class="section-title">人気のデータ記事</h2>
        <p class="section-lead">多くの野球ファンに読まれているデータ分析コンテンツ</p>
      </div>
      <ul class="article-list">
        <li>
          <a href="/glossary/sabermetrics/" class="article-item">
            <span class="article-rank gold">1</span>
            <div class="article-body">
              <p class="article-tag">指標解説 / 入門</p>
              <p class="article-title">セイバーメトリクスとは？野球データ分析の思想・歴史・主要指標を総まとめ</p>
              <p class="article-meta">入門記事 ・ 約10分で読めます</p>
            </div>
            <span class="article-arrow">›</span>
          </a>
        </li>
        <li>
          <a href="/glossary/war/" class="article-item">
            <span class="article-rank silver">2</span>
            <div class="article-body">
              <p class="article-tag">指標解説 / 総合</p>
              <p class="article-title">WARとは？大谷翔平10.5という数字が示す「1人で何勝分」の圧倒的価値</p>
              <p class="article-meta">指標解説 ・ 約7分で読めます</p>
            </div>
            <span class="article-arrow">›</span>
          </a>
        </li>
        <li>
          <a href="/glossary/ops/" class="article-item">
            <span class="article-rank bronze">3</span>
            <div class="article-body">
              <p class="article-tag">指標解説 / 打撃</p>
              <p class="article-title">OPS（出塁率+長打率）とは？打者の総合力を1つの数字で見る方法</p>
              <p class="article-meta">指標解説 ・ 約5分で読めます</p>
            </div>
            <span class="article-arrow">›</span>
          </a>
        </li>
        <li>
          <a href="/glossary/fip/" class="article-item">
            <span class="article-rank">4</span>
            <div class="article-body">
              <p class="article-tag">指標解説 / 投手</p>
              <p class="article-title">FIPとERAの違いを解説｜守備に左右されない投手評価指標</p>
              <p class="article-meta">指標解説 ・ 約8分で読めます</p>
            </div>
            <span class="article-arrow">›</span>
          </a>
        </li>
        <li>
          <a href="/mlb/leaders/" class="article-item">
            <span class="article-rank">5</span>
            <div class="article-body">
              <p class="article-tag">MLB / ランキング</p>
              <p class="article-title">MLB 2026 成績ランキング｜打率・本塁打・防御率リーダーボード</p>
              <p class="article-meta">2026年データ ・ 随時更新</p>
            </div>
            <span class="article-arrow">›</span>
          </a>
        </li>
        <li>
          <a href="/glossary/statcast/" class="article-item">
            <span class="article-rank">6</span>
            <div class="article-body">
              <p class="article-tag">指標解説 / Statcast</p>
              <p class="article-title">Statcastとは？MLBが導入した最新トラッキングシステムの全貌</p>
              <p class="article-meta">指標解説 ・ 約8分で読めます</p>
            </div>
            <span class="article-arrow">›</span>
          </a>
        </li>
      </ul>
    </div>
  </section>

  <!-- ===== AFFILIATE BANNER ===== -->
  <section class="affiliate-section">
    <div class="container">
      <div style="text-align:center; margin-bottom:0.5rem;">
        <span class="affiliate-label">スポンサー</span>
      </div>
      <h2 class="section-title">おすすめの野球グッズ・書籍</h2>
      <p class="section-lead">データ分析・スキルアップに役立つアイテムをご紹介</p>
      <div class="affiliate-grid">
        <a href="https://www.amazon.co.jp/dp/4880654779?tag=baseballab22-22" class="affiliate-card" target="_blank" rel="sponsored noopener">
          <div class="affiliate-thumb" style="background:#1b5e20">
            <img src="https://covers.openlibrary.org/b/isbn/4880654779-M.jpg" alt="" loading="lazy"
                 onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
            <span class="aff-icon-fallback" style="display:none">📗</span>
          </div>
          <div class="affiliate-info">
            <p class="badge-sponsor">スポンサー</p>
            <h3>セイバーメトリクス入門 脱常識で野球を科学する</h3>
            <p>データで野球を読み解く思想と主要指標を体系的に解説。指標解説をより深く理解したい人に最適。</p>
            <span class="affiliate-cta">Amazonで見る →</span>
          </div>
        </a>
        <a href="https://www.amazon.co.jp/dp/4768318029?tag=baseballab22-22" class="affiliate-card" target="_blank" rel="sponsored noopener">
          <div class="affiliate-thumb" style="background:#1a3a5c">
            <img src="https://covers.openlibrary.org/b/isbn/4768318029-M.jpg" alt="" loading="lazy"
                 onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
            <span class="aff-icon-fallback" style="display:none">📘</span>
          </div>
          <div class="affiliate-info">
            <p class="badge-sponsor">スポンサー</p>
            <h3>プロ野球・MLBが10倍楽しくなる！ よくわかるセイバーメトリクス</h3>
            <p>大谷翔平らの実数値を題材に、OPS・WAR・FIPからトラッキングデータまで図解。</p>
            <span class="affiliate-cta">Amazonで見る →</span>
          </div>
        </a>
        <a href="https://www.amazon.co.jp/dp/453406067X?tag=baseballab22-22" class="affiliate-card" target="_blank" rel="sponsored noopener">
          <div class="affiliate-thumb" style="background:#2d6a4f">
            <img src="https://covers.openlibrary.org/b/isbn/453406067X-M.jpg" alt="" loading="lazy"
                 onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
            <span class="aff-icon-fallback" style="display:none">🐍</span>
          </div>
          <div class="affiliate-info">
            <p class="badge-sponsor">スポンサー</p>
            <h3>野球データでやさしく学べるPython入門</h3>
            <p>プロ野球データを題材にPythonでの分析を実践習得。「読む」から「自分で分析する」へ。</p>
            <span class="affiliate-cta">Amazonで見る →</span>
          </div>
        </a>
        <a href="https://www.amazon.co.jp/dp/B00KGHXUZ4?tag=baseballab22-22" class="affiliate-card" target="_blank" rel="sponsored noopener">
          <div class="affiliate-thumb" style="background:#0f2540">
            <span class="aff-icon-fallback">📡</span>
          </div>
          <div class="affiliate-info">
            <p class="badge-sponsor">スポンサー</p>
            <h3>Pocket Radar ボールコーチ（スピードガン）</h3>
            <p>手のひらサイズで球速・打球速度を±1mph精度で計測。指導者・選手が自分のデータを取りに行くための実機。</p>
            <span class="affiliate-cta">Amazonで見る →</span>
          </div>
        </a>
      </div>
      <p class="affiliate-disclosure">当サイトはAmazonアソシエイト・プログラムの参加者です。適格販売により収入を得ることがあります。<a href="/disclosure/">詳細</a></p>
    </div>
  </section>

</Layout>
