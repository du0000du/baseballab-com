  {
    div: 'NL East',
    teams: [
      { slug: 'new-york-mets',        name: 'New York Mets',         abbr: 'NYM', color: '#002d72' },
      { slug: 'atlanta-braves',       name: 'Atlanta Braves',        abbr: 'ATL', color: '#ce1141' },
      { slug: 'philadelphia-phillies',name: 'Philadelphia Phillies', abbr: 'PHI', color: '#e81828' },
      { slug: 'washington-nationals', name: 'Washington Nationals',  abbr: 'WSH', color: '#ab0003' },
      { slug: 'miami-marlins',        name: 'Miami Marlins',         abbr: 'MIA', color: '#00a3e0' },
    ],
  },
  {
    div: 'NL Central',
    teams: [
      { slug: 'chicago-cubs',         name: 'Chicago Cubs',          abbr: 'CHC', color: '#0e3386' },
      { slug: 'st-louis-cardinals',   name: 'St. Louis Cardinals',   abbr: 'STL', color: '#c41e3a' },
      { slug: 'milwaukee-brewers',    name: 'Milwaukee Brewers',     abbr: 'MIL', color: '#12284b' },
      { slug: 'cincinnati-reds',      name: 'Cincinnati Reds',       abbr: 'CIN', color: '#c6011f' },
      { slug: 'pittsburgh-pirates',   name: 'Pittsburgh Pirates',    abbr: 'PIT', color: '#fdb827' },
    ],
  },
  {
    div: 'NL West',
    teams: [
      { slug: 'los-angeles-dodgers',  name: 'Los Angeles Dodgers',   abbr: 'LAD', color: '#005a9c' },
      { slug: 'san-francisco-giants', name: 'San Francisco Giants',  abbr: 'SF',  color: '#fd5a1e' },
      { slug: 'san-diego-padres',     name: 'San Diego Padres',      abbr: 'SD',  color: '#2f241d' },
      { slug: 'arizona-diamondbacks', name: 'Arizona Diamondbacks',  abbr: 'ARI', color: '#a71930' },
      { slug: 'colorado-rockies',     name: 'Colorado Rockies',      abbr: 'COL', color: '#33006f' },
    ],
  },
