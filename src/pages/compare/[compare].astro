---
import Layout from '../../layouts/Layout.astro';
import ShareButtons from '../../components/ShareButtons.astro';
import { readFileSync, readdirSync } from 'node:fs';
import { join } from 'node:path';

export async function getStaticPaths() {
  const dir = join(process.cwd(), 'data/mlb/players');
  const files = readdirSync(dir).filter(f => f.endsWith('.json'));

  const players: { slug: string; data: any; score: number }[] = [];
  for (const file of files) {
    const slug = file.replace('.json', '');
    let data: any;
    try {
      data = JSON.parse(readFileSync(join(dir, file), 'utf-8'));
    } catch { continue; }
    const info = data.info ?? {};
    const stat = data.stats?.[0]?.splits?.[0]?.stat ?? {};
    const group = data.stats?.[0]?.group?.displayName ?? '';
    let score = info.active ? 100 : 0;
    if (group === 'hitting') {
      score += Number(stat.gamesPlayed || 0) * 2;
      score += Number(stat.homeRuns || 0) * 4;
      score += Number(stat.rbi || 0);
      score += Number(stat.hits || 0) * 0.5;
    } else if (group === 'pitching') {
      score += Number(stat.gamesPlayed || 0) * 2;
      score += Number(stat.wins || 0) * 6;
      score += Number(stat.strikeOuts || 0) * 0.5;
      score += Number(stat.saves || 0) * 3;
    }
    players.push({ slug, data, score });
  }

  players.sort((a, b) => b.score - a.score);
  const top = players.slice(0, 60);

  const paths = [];
  for (let i = 0; i < top.length; i++) {
    for (let j = i + 1; j < top.length; j++) {
      const a = top[i];
      const b = top[j];
      paths.push({
        params: { compare: `${a.slug}-vs-${b.slug}` },
        props: { dataA: a.data, dataB: b.data, slugA: a.slug, slugB: b.slug },
      });
    }
  }
  return paths;
}

const { dataA, dataB, slugA, slugB } = Astro.props;

function extract(d: any) {
  const info = d.info ?? {};
  const entry = d.stats?.[0] ?? {};
  const group = entry.group?.displayName ?? '';
  const stat = entry.splits?.[0]?.stat ?? {};
  const team = entry.splits?.[0]?.team?.name ?? '';
  return {
    name: info.fullName ?? 'Unknown',
    pos: info.primaryPosition?.abbreviation ?? '',
    active: info.active ?? false,
    team,
    group,
    stat,
  };
}

const A = extract(dataA);
const B = extract(dataB);

function f3(v: any) { if (v == null) return '—'; const n = Number(v); return isNaN(n) ? '—' : n.toFixed(3); }
function f2(v: any) { if (v == null) return '—'; const n = Number(v); return isNaN(n) ? '—' : n.toFixed(2); }
function fi(v: any) { if (v == null) return '—'; const n = Number(v); return isNaN(n) ? '—' : String(n); }

// 打者比較行: [label, valA, valB, higherIsBetter]
type Row = [string, string, string, boolean];

const hitterRows: Row[] = [
  ['試合', fi(A.stat.gamesPlayed), fi(B.stat.gamesPlayed), true],
  ['打率', f3(A.stat.avg), f3(B.stat.avg), true],
  ['本塁打', fi(A.stat.homeRuns), fi(B.stat.homeRuns), true],
  ['打点', fi(A.stat.rbi), fi(B.stat.rbi), true],
  ['安打', fi(A.stat.hits), fi(B.stat.hits), true],
  ['得点', fi(A.stat.runs), fi(B.stat.runs), true],
  ['盗塁', fi(A.stat.stolenBases), fi(B.stat.stolenBases), true],
  ['出塁率', f3(A.stat.obp), f3(B.stat.obp), true],
  ['長打率', f3(A.stat.slg), f3(B.stat.slg), true],
  ['OPS', f3(A.stat.ops), f3(B.stat.ops), true],
];

const pitcherRows: Row[] = [
  ['試合', fi(A.stat.gamesPlayed), fi(B.stat.gamesPlayed), true],
  ['勝利', fi(A.stat.wins), fi(B.stat.wins), true],
  ['敗戦', fi(A.stat.losses), fi(B.stat.losses), false],
  ['防御率', f2(A.stat.era), f2(B.stat.era), false],
  ['奪三振', fi(A.stat.strikeOuts), fi(B.stat.strikeOuts), true],
  ['WHIP', f2(A.stat.whip), f2(B.stat.whip), false],
  ['投球回', A.stat.inningsPitched ?? '—', B.stat.inningsPitched ?? '—', true],
  ['セーブ', fi(A.stat.saves), fi(B.stat.saves), true],
];

const isAHitter = A.group === 'hitting';
const isBHitter = B.group === 'hitting';
const bothHitters = isAHitter && isBHitter;
const bothPitchers = !isAHitter && !isBHitter;

function winner(valA: string, valB: string, higherIsBetter: boolean): 'a' | 'b' | 'tie' {
  if (valA === '—' || valB === '—') return 'tie';
  const na = Number(valA);
  const nb = Number(valB);
  if (isNaN(na) || isNaN(nb)) return 'tie';
  if (na === nb) return 'tie';
  return higherIsBetter ? (na > nb ? 'a' : 'b') : (na < nb ? 'a' : 'b');
}

const rows: Row[] = bothHitters ? hitterRows : bothPitchers ? pitcherRows : hitterRows;

const pageTitle = `${A.name} vs ${B.name} — 成績比較 | Baseballab`;
const description = `${A.name}（${A.pos}）と${B.name}（${B.pos}）の${new Date().getFullYear()}年MLB成績を徹底比較。打率・本塁打・防御率などの主要指標を並べて確認できます。`;
const ogUrl = `https://baseballab.com/compare/${slugA}-vs-${slugB}/`;
---

<Layout title={pageTitle} description={description} ogUrl={ogUrl}>
  <div class="container">
    <nav class="breadcrumb">
      <a href="/">TOP</a> › <a href="/players/">MLB 選手</a> › 選手比較
    </nav>

    <h1 class="page-title">選手比較</h1>

    <!-- プレイヤーヘッダー -->
    <div class="vs-header">
      <div class="player-card">
        <a href={`/players/${slugA}/`} class="player-link">
          <div class="player-name">{A.name}</div>
          <div class="player-meta">{A.pos}{A.team ? ` · ${A.team}` : ''}</div>
        </a>
      </div>
      <div class="vs-badge">VS</div>
      <div class="player-card">
        <a href={`/players/${slugB}/`} class="player-link">
          <div class="player-name">{B.name}</div>
          <div class="player-meta">{B.pos}{B.team ? ` · ${B.team}` : ''}</div>
        </a>
      </div>
    </div>

    <!-- 成績比較テーブル -->
    <div class="compare-table-wrap">
      {(!bothHitters && !bothPitchers) && (
        <p class="mixed-note">※ 打者と投手の比較のため、打撃成績を表示しています</p>
      )}
      <table class="compare-table">
        <thead>
          <tr>
            <th class="col-a">{A.name.split(' ').at(-1)}</th>
            <th class="col-label">指標</th>
            <th class="col-b">{B.name.split(' ').at(-1)}</th>
          </tr>
        </thead>
        <tbody>
          {rows.map(([label, valA, valB, higherIsBetter]) => {
            const w = winner(valA, valB, higherIsBetter);
            return (
              <tr>
                <td class={`col-a val ${w === 'a' ? 'win' : w === 'tie' ? '' : 'lose'}`}>{valA}</td>
                <td class="col-label label">{label}</td>
                <td class={`col-b val ${w === 'b' ? 'win' : w === 'tie' ? '' : 'lose'}`}>{valB}</td>
              </tr>
            );
          })}
        </tbody>
      </table>
    </div>

    <ShareButtons title={pageTitle} url={ogUrl} />

    <!-- 選手個別ページへのリンク -->
    <div class="player-links">
      <a href={`/players/${slugA}/`} class="btn-outline">→ {A.name} の詳細データ</a>
      <a href={`/players/${slugB}/`} class="btn-outline">→ {B.name} の詳細データ</a>
    </div>
  </div>
</Layout>

<style>
  .container {
    max-width: 800px;
    margin: 0 auto;
    padding: 2rem 1.25rem 4rem;
  }
  .breadcrumb {
    font-size: 0.8rem;
    color: var(--gray-600);
    margin-bottom: 1.25rem;
  }
  .breadcrumb a { color: var(--gray-600); }
  .page-title {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--gray-600);
    margin-bottom: 1.25rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  /* ヘッダー */
  .vs-header {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 1rem;
    background: var(--navy-dark);
    border-radius: 12px;
    padding: 1.5rem;
    margin-bottom: 1.5rem;
    color: #fff;
  }
  .player-card { text-align: center; }
  .player-link { color: #fff; text-decoration: none; display: block; }
  .player-link:hover .player-name { text-decoration: underline; }
  .player-name {
    font-size: clamp(1rem, 2.5vw, 1.4rem);
    font-weight: 800;
    line-height: 1.2;
    margin-bottom: 0.3rem;
  }
  .player-meta { font-size: 0.8rem; opacity: 0.7; }
  .vs-badge {
    font-size: 1.3rem;
    font-weight: 900;
    color: var(--red);
    text-align: center;
    flex-shrink: 0;
  }

  /* テーブル */
  .compare-table-wrap { margin-bottom: 1.5rem; overflow-x: auto; }
  .mixed-note {
    font-size: 0.78rem;
    color: var(--gray-600);
    margin-bottom: 0.75rem;
  }
  .compare-table {
    width: 100%;
    border-collapse: collapse;
    table-layout: fixed;
  }
  .compare-table th, .compare-table td {
    padding: 0.65rem 0.75rem;
    border-bottom: 1px solid var(--border);
    font-size: 0.95rem;
  }
  .compare-table th {
    background: var(--gray-100);
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--gray-600);
  }
  .col-a, .compare-table .col-a { text-align: right; }
  .col-b, .compare-table .col-b { text-align: left; }
  .col-label { text-align: center; color: var(--gray-600); font-size: 0.82rem; width: 5rem; }
  .val { font-weight: 700; font-variant-numeric: tabular-nums; }
  .val.win { color: var(--navy); background: rgba(26,58,92,0.07); }
  .val.lose { color: var(--gray-400); }

  /* ボタン */
  .player-links {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-top: 1rem;
  }
  .btn-outline {
    display: inline-block;
    border: 2px solid var(--navy);
    color: var(--navy);
    padding: 0.55rem 1.1rem;
    border-radius: 6px;
    font-size: 0.875rem;
    font-weight: 600;
    text-decoration: none;
    transition: background 0.15s, color 0.15s;
  }
  .btn-outline:hover { background: var(--navy); color: #fff; }

  @media (max-width: 480px) {
    .player-name { font-size: 0.95rem; }
    .compare-table th, .compare-table td { padding: 0.5rem 0.4rem; font-size: 0.85rem; }
  }
</style>
