      .breadcrumb a { color: var(--navy); text-decoration: none; }
      .breadcrumb a:hover { text-decoration: underline; }
      main { max-width: 780px; margin: 0 auto; padding: 3rem 1.25rem 4rem; }
      h1 { font-size: clamp(1.5rem, 3vw, 2rem); font-weight: 800; color: var(--navy); margin-bottom: 0.5rem; letter-spacing: -0.02em; }
      .updated { font-size: 0.82rem; color: var(--gray-600); margin-bottom: 2.5rem; }
      h2 { font-size: 1.1rem; font-weight: 700; color: var(--navy); margin: 2.25rem 0 0.6rem; padding-left: 0.7rem; border-left: 3px solid var(--red); }
      p { margin-bottom: 1rem; }
      a { color: var(--navy); }
      .site-footer { background: var(--navy-dark); color: rgba(255,255,255,0.6); text-align: center; padding: 2rem 1.25rem; font-size: 0.85rem; }
      .footer-nav { display: flex; justify-content: center; gap: 1.5rem; margin-bottom: 1rem; flex-wrap: wrap; }
      .footer-nav a:hover { color: #fff; }
    </style>
  </head>
  <body>
    <header class="site-header">
      <div class="header-inner">
        <a href="/" class="site-logo">⚾ Basel<span>lab</span></a>
