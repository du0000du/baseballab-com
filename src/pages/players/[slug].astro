---
import Layout from '../../layouts/Layout.astro';
import AtomicAnswer from '../../components/AtomicAnswer.astro';
import AffiliateBlock from '../../components/AffiliateBlock.astro';
import GlossaryLinks from '../../components/GlossaryLinks.astro';
import { readFileSync, readdirSync } from 'node:fs';
import { join } from 'node:path';
const SEASON_YEAR = new Date().getMonth() + 1 >= 3 ? new Date().getFullYear() : new Date().getFullYear() - 1; // 3月以降は当年、1〜2月は前年

export async function getStaticPaths() {
  const dir = join(process.cwd(), 'data/mlb/players');
  const files = readdirSync(dir).filter(f => f.endsWith('.json'));

  return files.map(file => {
    const slug = file.replace('.json', '');
    const raw = readFileSync(join(dir, file), 'utf-8');
    const data = JSON.parse(raw);
    return { params: { slug }, props: { data } };
  });
}

const { data } = Astro.props;
const { info } = data;

const name = info.fullName ?? 'Unknown Player';
const position = info.primaryPosition?.name ?? 'Player';
const posAbbr = info.primaryPosition?.abbreviation ?? '';
const number = info.primaryNumber ? `#${info.primaryNumber}` : '';
const birthDate = info.birthDate ?? null;
const birthCity = info.birthCity ?? '';
const birthCountry = info.birthCountry ?? '';
const height = info.height ?? '';
const weight = info.weight ? `${info.weight} lbs` : '';
const bats = info.batSide?.description ?? '';
const throws = info.pitchHand?.description ?? '';
const debut = info.mlbDebutDate ?? null;
const age = info.currentAge ?? null;

// 2026年成績データ
const statsEntry = data.stats?.[0] ?? null;
const statGroup = statsEntry?.group?.displayName ?? '';
const splitStat = statsEntry?.splits?.[0]?.stat ?? null;
const teamName = statsEntry?.splits?.[0]?.team?.name ?? '';

const isBatter = statGroup === 'hitting';
const isPitcher = statGroup === 'pitching';

const avg = splitStat?.avg ?? null;
const hr = splitStat?.homeRuns ?? null;
const rbi = splitStat?.rbi ?? null;
const ops = splitStat?.ops ?? null;
const gamesPlayed = splitStat?.gamesPlayed ?? null;
const hits = splitStat?.hits ?? null;
const sb = splitStat?.stolenBases ?? null;
const runs = splitStat?.runs ?? null;

// 投手成績
const era = splitStat?.era ?? null;
const wins = splitStat?.wins ?? null;
const losses = splitStat?.losses ?? null;
const strikeOuts = splitStat?.strikeOuts ?? null;
const whip = splitStat?.whip ?? null;
const ip = splitStat?.inningsPitched ?? null;
const saves = splitStat?.saves ?? null;

function f3(v: any): string { if (v == null) return '—'; const n = Number(v); return isNaN(n) ? '—' : n.toFixed(3); }
function f2(v: any): string { if (v == null) return '—'; const n = Number(v); return isNaN(n) ? '—' : n.toFixed(2); }

// atomicText — 成績ベースの紹介文
let statsSnippet = '';
if (isBatter && avg) {
  const parts = [];
  if (avg) parts.push(`打率${avg}`);
  if (hr !== null) parts.push(`${hr}本塁打`);
  if (rbi !== null) parts.push(`${rbi}打点`);
  if (ops) parts.push(`OPS ${ops}`);
  statsSnippet = parts.length ? `${SEASON_YEAR}年は${parts.join('・')}を記録。` : '';
} else if (isPitcher && era) {
  const parts = [];
  if (wins !== null && losses !== null) parts.push(`${wins}勝${losses}敗`);
  if (era) parts.push(`防御率${era}`);
  if (strikeOuts !== null) parts.push(`${strikeOuts}奪三振`);
  statsSnippet = parts.length ? `${SEASON_YEAR}年は${parts.join('・')}を記録。` : '';
}

const teamSnippet = teamName ? `所属チーム: ${teamName}。` : '';
const atomicText = `${name}（${posAbbr}）はMLBの現役選手。${birthCountry ? birthCountry + '出身。' : ''}${statsSnippet}${teamSnippet}最新成績はBaseballabで確認できます。`;

// 断言テキスト（MLB平均: OPS.720, ERA 4.00 基準）
let verdict = '';
if (isBatter && ops) {
  const o = Number(ops);
  if (o >= 0.950) verdict = `OPS ${ops} はMLBトップクラス。リーグ平均（.720前後）を大幅に上回る最高水準の打者。`;
  else if (o >= 0.850) verdict = `OPS ${ops} はMLBリーグ平均（.720前後）を大きく上回る。スター打者として申し分ない数値。`;
  else if (o >= 0.720) verdict = `OPS ${ops} はMLBリーグ平均水準。安定したレギュラーとして計算できる打者。`;
  else if (o > 0) verdict = `OPS ${ops} はMLBリーグ平均（.720前後）をやや下回る。出塁率か長打率の向上が課題。`;
} else if (isPitcher && era) {
  const e = Number(era);
  if (e <= 2.50) verdict = `防御率 ${era} はMLBトップクラス。ローテーションの絶対的エース水準。`;
  else if (e <= 3.50) verdict = `防御率 ${era} はMLBリーグ平均（4.00前後）を大きく上回る好成績。信頼できる先発投手。`;
  else if (e <= 4.00) verdict = `防御率 ${era} はMLBリーグ平均水準。安定したローテーション投手。`;
  else if (e > 0) verdict = `防御率 ${era} はMLBリーグ平均（4.00前後）を上回る。安定感の改善が求められる。`;
}

const pageTitle = `${name} 成績・プロフィール`;
const description = `${name}（${posAbbr}）のMLB成績・プロフィール・最新情報。${birthCountry ? birthCountry + '出身。' : ''}${statsSnippet}Baseballabで詳細データを確認。`;
const ogUrl = `https://baseballab.com/players/${Astro.params.slug}/`;
const jsonLd: Record<string, any> = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name,
  description: atomicText,
  url: ogUrl,
  ...(birthDate && { birthDate }),
  ...(birthCountry && { nationality: birthCountry }),
  memberOf: {
    '@type': 'SportsTeam',
    name: teamName || 'MLB',
    sport: 'Baseball',
    memberOf: { '@type': 'SportsOrganization', name: 'MLB' },
  },
};
const affiliateLinks = [
  { label: 'セイバーメトリクス入門 脱常識で野球を科学する', url: 'https://www.amazon.co.jp/dp/4880654779?tag=baseballab22-22', pr: true, description: 'データで野球を読み解く思想と主要指標を体系的に解説。指標解説をより深く理解したい人に最適。', icon: '📗', bgColor: '#1b5e20', imgUrl: 'https://m.media-amazon.com/images/I/519rUSeuIYL.jpg' },
  { label: 'プロ野球・MLBが10倍楽しくなる！ よくわかるセイバーメトリクス', url: 'https://www.amazon.co.jp/dp/4768318029?tag=baseballab22-22', pr: true, description: '大谷翔平らの実数値を題材に、OPS・WAR・FIPからトラッキングデータまで図解。', icon: '📘', bgColor: '#1a3a5c', imgUrl: 'https://m.media-amazon.com/images/I/51lStvg+NoL.jpg' },
  { label: '野球データでやさしく学べるPython入門', url: 'https://www.amazon.co.jp/dp/453406067X?tag=baseballab22-22', pr: true, description: 'プロ野球データを題材にPythonでの分析を実践習得。「読む」から「自分で分析する」へ。', icon: '🐍', bgColor: '#2d6a4f', imgUrl: 'https://m.media-amazon.com/images/I/51EilUzMNvL.jpg' },
  { label: 'Pocket Radar ボールコーチ（スピードガン）', url: 'https://www.amazon.co.jp/dp/B00KGHXUZ4?tag=baseballab22-22', pr: true, description: '手のひらサイズで球速・打球速度を±1mph精度で計測。指導者・選手が自分のデータを取りに行くための実機。', icon: '📡', bgColor: '#0f2540', imgUrl: 'https://m.media-amazon.com/images/I/41+v5H4-36L._AC_.jpg' },
];
---
<Layout title={pageTitle} description={description} ogUrl={ogUrl} jsonLd={jsonLd}>
  <style slot="head">
  .player-hero {
    background: var(--navy-dark, #0c1e33);
    color: #fff;
    padding: 3rem 0 2rem;
  }
  .player-hero .container {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .player-number {
    font-size: 0.9rem;
    opacity: 0.7;
    font-weight: 600;
  }
  .player-hero h1 {
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    font-weight: 800;
    margin: 0;
  }
  .player-position-badge {
    display: inline-block;
    background: rgba(255,255,255,0.15);
    padding: 0.2rem 0.75rem;
    border-radius: 20px;
    font-size: 0.85rem;
    font-weight: 600;
    width: fit-content;
  }
  .player-body { padding: 2rem 0 4rem; }
  .info-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 1rem;
    margin: 2rem 0;
  }
  .info-item {
    background: var(--gray-100, #f2f0ec);
    border: 1px solid var(--border, #e4e2dc);
    border-radius: 8px;
    padding: 1rem 1.1rem;
  }
  .info-label {
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--gray-500, #8a8680);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin: 0 0 0.25rem;
  }
  .info-value {
    font-size: 1rem;
    font-weight: 600;
    color: var(--text, #212529);
    margin: 0;
  }
  /* 成績カード */
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
    gap: 1rem;
    margin: 1.5rem 0 2rem;
  }
  .stat-card {
    background: var(--bg-card, #ffffff);
    border: 1px solid var(--border, #e4e2dc);
    border-radius: 10px;
    padding: 1.25rem 1rem;
    text-align: center;
    box-shadow: var(--shadow-sm);
    transition: box-shadow var(--transition);
  }
  .stat-card:hover {
    box-shadow: var(--shadow-md);
  }
  .stat-label {
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--gray-500, #8a8680);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin: 0 0 0.4rem;
  }
  .stat-value {
    font-size: 1.8rem;
    font-weight: 800;
    color: var(--navy, #152a42);
    margin: 0;
    line-height: 1;
    font-variant-numeric: tabular-nums;
    font-family: var(--font-en);
  }
  .stat-value.highlight {
    color: var(--accent, #9b2335);
  }
  .stat-sub {
    font-size: 0.75rem;
    color: var(--gray-400, #a8a49a);
    margin: 0.3rem 0 0;
  }
  .stats-team {
    font-size: 0.85rem;
    color: var(--gray-600, #6b6760);
    margin: 0 0 0.25rem;
  }
  .stats-asof {
    font-size: 0.75rem;
    color: var(--gray-500, #8a8680);
    margin: 0 0 1rem;
  }
  .stats-placeholder {
    background: var(--gray-100, #f2f0ec);
    border: 2px dashed var(--gray-200, #e4e2dc);
    border-radius: 8px;
    padding: 2rem 1.5rem;
    text-align: center;
    color: var(--gray-600, #6b6760);
    margin: 2rem 0;
  }
  .breadcrumb {
    font-size: 0.85rem;
    color: rgba(255,255,255,0.7);
    margin-bottom: 1rem;
  }
  .breadcrumb a { color: rgba(255,255,255,0.7); text-decoration: none; }
  .breadcrumb a:hover { color: #fff; }
  .verdict { margin: 0 0 1.5rem; padding: .75rem 1rem; background: var(--gray-100, #f2f0ec); border-left: 3px solid var(--accent, #9b2335); border-radius: 0 6px 6px 0; font-size: .88rem; color: var(--gray-700, #4a4640); line-height: 1.65; }
  .sl { color: inherit; text-decoration: none; border-bottom: 1px dotted currentColor; }
  .sl:hover { color: var(--accent, #9b2335); border-color: var(--accent, #9b2335); }
  .see-rankings { margin: 1.5rem 0 0; }
  .see-rankings-heading { font-size: .78rem; font-weight: 700; color: var(--gray-500, #8a8680); text-transform: uppercase; letter-spacing: .06em; margin: 0 0 .6rem; }
  .see-rankings-list { display: flex; flex-wrap: wrap; gap: .4rem; list-style: none; padding: 0; margin: 0; }
  .see-rankings-list a { display: inline-block; background: var(--bg-card, #fff); border: 1px solid var(--border, #e4e2dc); border-radius: 20px; padding: .18rem .7rem; font-size: .8rem; font-weight: 600; color: var(--navy); text-decoration: none; }
  .see-rankings-list a:hover { border-color: var(--accent, #9b2335); color: var(--accent, #9b2335); }
  @media (max-width: 600px) {
    .info-grid { grid-template-columns: repeat(2, 1fr); gap: 0.75rem; }
    .stats-grid { grid-template-columns: repeat(2, 1fr); gap: 0.75rem; }
    .player-hero { padding: 2rem 0 1.5rem; }
    .player-body { padding: 1.5rem 0 3rem; }
  }
  @media (max-width: 380px) {
    .info-grid { grid-template-columns: 1fr; }
    .stats-grid { grid-template-columns: repeat(2, 1fr); }
    .info-item { padding: 0.875rem 1rem; }
    .player-hero h1 { font-size: 1.7rem; }
  }
  </style>

  <section class="player-hero">
    <div class="container">
      <nav class="breadcrumb" aria-label="パンくずリスト">
        <a href="/">Baseballab</a> &rsaquo; <a href="/players/">MLB選手</a> &rsaquo; {name}
      </nav>
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Baseballab", "item": "https://baseballab.com/" },
          { "@type": "ListItem", "position": 2, "name": "MLB選手", "item": "https://baseballab.com/players/" },
          { "@type": "ListItem", "position": 3, "name": name }
        ]
      })} />
      {number && <p class="player-number">{number}</p>}
      <h1>{name}</h1>
      <span class="player-position-badge">{position}</span>
    </div>
  </section>

  <div class="player-body">
    <div class="container">
      <AtomicAnswer text={atomicText} />

      <h2>プロフィール</h2>
      <div class="info-grid">
        {birthDate && (
          <div class="info-item">
            <p class="info-label">生年月日</p>
            <p class="info-value">{birthDate}{age ? ` (${age}歳)` : ''}</p>
          </div>
        )}
        {(birthCity || birthCountry) && (
          <div class="info-item">
            <p class="info-label">出身</p>
            <p class="info-value">{[birthCity, birthCountry].filter(Boolean).join(', ')}</p>
          </div>
        )}
        {height && (
          <div class="info-item">
            <p class="info-label">身長</p>
            <p class="info-value">{height}</p>
          </div>
        )}
        {weight && (
          <div class="info-item">
            <p class="info-label">体重</p>
            <p class="info-value">{weight}</p>
          </div>
        )}
        {bats && (
          <div class="info-item">
            <p class="info-label">打席</p>
            <p class="info-value">{bats}</p>
          </div>
        )}
        {throws && (
          <div class="info-item">
            <p class="info-label">投球腕</p>
            <p class="info-value">{throws}</p>
          </div>
        )}
        {debut && (
          <div class="info-item">
            <p class="info-label">MLBデビュー</p>
            <p class="info-value">{debut}</p>
          </div>
        )}
      </div>

      <h2>{SEASON_YEAR}年成績</h2>
      {teamName && <p class="stats-team">{teamName}</p>}
      <p class="stats-asof">MLB Stats API データ（{SEASON_YEAR}シーズン）</p>

      {isBatter && splitStat ? (
        <div class="stats-grid">
          {avg != null && <div class="stat-card"><p class="stat-label"><a href="/glossary/avg/" class="sl">打率</a></p><p class="stat-value">{f3(avg)}</p><p class="stat-sub">AVG</p></div>}
          {hr !== null && <div class="stat-card"><p class="stat-label"><a href="/glossary/hr/" class="sl">本塁打</a></p><p class="stat-value highlight">{hr}</p><p class="stat-sub">HR</p></div>}
          {rbi !== null && <div class="stat-card"><p class="stat-label"><a href="/glossary/rbi/" class="sl">打点</a></p><p class="stat-value">{rbi}</p><p class="stat-sub">RBI</p></div>}
          {ops != null && <div class="stat-card"><p class="stat-label"><a href="/glossary/ops/" class="sl">OPS</a></p><p class="stat-value">{f3(ops)}</p><p class="stat-sub">出塁+長打</p></div>}
          {runs !== null && <div class="stat-card"><p class="stat-label">得点</p><p class="stat-value">{runs}</p><p class="stat-sub">R</p></div>}
          {hits !== null && <div class="stat-card"><p class="stat-label">安打</p><p class="stat-value">{hits}</p><p class="stat-sub">H</p></div>}
          {sb !== null && sb > 0 && <div class="stat-card"><p class="stat-label">盗塁</p><p class="stat-value">{sb}</p><p class="stat-sub">SB</p></div>}
          {gamesPlayed !== null && <div class="stat-card"><p class="stat-label">試合</p><p class="stat-value">{gamesPlayed}</p><p class="stat-sub">G</p></div>}
        </div>
      ) : isPitcher && splitStat ? (
        <div class="stats-grid">
          {era != null && <div class="stat-card"><p class="stat-label"><a href="/glossary/era/" class="sl">防御率</a></p><p class="stat-value highlight">{f2(era)}</p><p class="stat-sub">ERA</p></div>}
          {wins !== null && losses !== null && <div class="stat-card"><p class="stat-label">勝敗</p><p class="stat-value">{wins}-{losses}</p><p class="stat-sub">W-L</p></div>}
          {strikeOuts !== null && <div class="stat-card"><p class="stat-label"><a href="/glossary/strikeout/" class="sl">奪三振</a></p><p class="stat-value">{strikeOuts}</p><p class="stat-sub">K</p></div>}
          {whip != null && <div class="stat-card"><p class="stat-label"><a href="/glossary/whip/" class="sl">WHIP</a></p><p class="stat-value">{f2(whip)}</p><p class="stat-sub">BB+H/IP</p></div>}
          {ip && <div class="stat-card"><p class="stat-label">投球回</p><p class="stat-value">{ip}</p><p class="stat-sub">IP</p></div>}
          {saves !== null && saves > 0 && <div class="stat-card"><p class="stat-label"><a href="/glossary/sv/" class="sl">セーブ</a></p><p class="stat-value">{saves}</p><p class="stat-sub">SV</p></div>}
          {gamesPlayed !== null && <div class="stat-card"><p class="stat-label">登板</p><p class="stat-value">{gamesPlayed}</p><p class="stat-sub">G</p></div>}
        </div>
      ) : (
        <div class="stats-placeholder">
          <p>📊 成績データは近日更新予定です。</p>
          <p style="font-size: 0.85rem; margin-top: 0.5rem;">MLB Stats API からの取得・整形を実施中。</p>
        </div>
      )}
      {verdict && <p class="verdict">{verdict}</p>}
      <GlossaryLinks type={isBatter ? 'batting' : 'pitching'} />
      <div class="see-rankings">
        <p class="see-rankings-heading">成績ランキングで見る</p>
        <ul class="see-rankings-list">
          <li><a href="/mlb/leaders/">MLB 成績ランキング（AL/NL）</a></li>
          <li><a href="/mlb/standings/">MLB 順位表</a></li>
          <li><a href="/players/">MLB 選手一覧</a></li>
        </ul>
      </div>
      <AffiliateBlock links={affiliateLinks} heading="この選手をさらに知るためのおすすめ" />
</div>
  </div>
</Layout>
