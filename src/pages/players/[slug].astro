---
import Layout from '../../layouts/Layout.astro';
import AtomicAnswer from '../../components/AtomicAnswer.astro';
import AffiliateBlock from '../../components/AffiliateBlock.astro';
import { readFileSync, readdirSync } from 'node:fs';
import { join } from 'node:path';
const SEASON_YEAR = new Date().getMonth() + 1 >= 3 ? new Date().getFullYear() : new Date().getFullYear() - 1; // 3月以降は当年、1〜2月は前年

export async function getStaticPaths() {
  const dir = join(process.cwd(), 'data/mlb/players');
  const files = readdirSync(dir).filter(f => f.endsWith('.json'));

  return files.map(file => {
    const slug = file.replace('.json', '');
    const raw = readFileSync(join(dir, file), 'utf-8');
    const data = JSON.parse(raw);
    return { params: { slug }, props: { data } };
  });
}

const { data } = Astro.props;
const { info } = data;

const name = info.fullName ?? 'Unknown Player';
const position = info.primaryPosition?.name ?? 'Player';
const posAbbr = info.primaryPosition?.abbreviation ?? '';
const number = info.primaryNumber ? `#${info.primaryNumber}` : '';
const birthDate = info.birthDate ?? null;
const birthCity = info.birthCity ?? '';
const birthCountry = info.birthCountry ?? '';
const height = info.height ?? '';
const weight = info.weight ? `${info.weight} lbs` : '';
const bats = info.batSide?.description ?? '';
const throws = info.pitchHand?.description ?? '';
const debut = info.mlbDebutDate ?? null;
const age = info.currentAge ?? null;

// 2026年成績データ
const statsEntry = data.stats?.[0] ?? null;
const statGroup = statsEntry?.group?.displayName ?? '';
const splitStat = statsEntry?.splits?.[0]?.stat ?? null;
const teamName = statsEntry?.splits?.[0]?.team?.name ?? '';

// 打撃成績
const isBatter = statGroup === 'hitting';
const isPitcher = statGroup === 'pitching';

const avg = splitStat?.avg ?? null;
const hr = splitStat?.homeRuns ?? null;
const rbi = splitStat?.rbi ?? null;
const ops = splitStat?.ops ?? null;
const gamesPlayed = splitStat?.gamesPlayed ?? null;
const hits = splitStat?.hits ?? null;
const sb = splitStat?.stolenBases ?? null;
const runs = splitStat?.runs ?? null;

// 投手成績
const era = splitStat?.era ?? null;
const wins = splitStat?.wins ?? null;
const losses = splitStat?.losses ?? null;
const strikeOuts = splitStat?.strikeOuts ?? null;
const whip = splitStat?.whip ?? null;
const ip = splitStat?.inningsPitched ?? null;
const saves = splitStat?.saves ?? null;

// atomicText — 成績ベースの紹介文
let statsSnippet = '';
if (isBatter && avg) {
  const parts = [];
  if (avg) parts.push(`打率${avg}`);
  if (hr !== null) parts.push(`${hr}本塁打`);
  if (rbi !== null) parts.push(`${rbi}打点`);
  if (ops) parts.push(`OPS ${ops}`);
  statsSnippet = parts.length ? `${SEASON_YEAR}年は${parts.join('・')}を記録。` : '';
} else if (isPitcher && era) {
  const parts = [];
  if (wins !== null && losses !== null) parts.push(`${wins}勝${losses}敗`);
  if (era) parts.push(`防御率${era}`);
  if (strikeOuts !== null) parts.push(`${strikeOuts}奪三振`);
  statsSnippet = parts.length ? `${SEASON_YEAR}年は${parts.join('・')}を記録。` : '';
}

const teamSnippet = teamName ? `所属チーム: ${teamName}。` : '';
const atomicText = `${name}（${posAbbr}）はMLBの現役選手。${birthCountry ? birthCountry + '出身。' : ''}${statsSnippet}${teamSnippet}最新成績はBaseballabで確認できます。`;

const pageTitle = `${name} 成績・プロフィール`;
const description = `${name}（${posAbbr}）のMLB成績・プロフィール・最新情報。${birthCountry ? birthCountry + '出身。' : ''}${statsSnippet}Baseballabで詳細データを確認。`;
const AMAZON_TAG = 'baseballab22-22';
const affiliateLinks = [
  { label: 'データで勝つ野球 セイバーメトリクス入門', url: `https://www.amazon.co.jp/s?k=%E3%83%87%E3%83%BC%E3%82%BF%E3%81%A7%E5%8B%9D%E3%81%A4%E9%87%8E%E7%90%83+%E3%82%BB%E3%82%A4%E3%83%90%E3%83%BC%E3%83%A1%E3%83%88%E3%83%AA%E3%82%AF%E3%82%B9&tag=${AMAZON_TAG}`, pr: true, description: '指標で読み解く野球分析の入門書' },
  { label: '野球スコアブック 公式記録員監修版', url: `https://www.amazon.co.jp/s?k=%E9%87%8E%E7%90%83+%E3%82%B9%E3%82%B3%E3%82%A2%E3%83%96%E3%83%83%E3%82%AF+%E5%85%AC%E5%BC%8F&tag=${AMAZON_TAG}`, pr: true, description: '試合記録をつけて選手成績をより深く理解' },
  { label: 'ラプソード MLM2 PRO', url: `https://www.amazon.co.jp/s?k=%E3%83%A9%E3%83%97%E3%82%BD%E3%83%BC%E3%83%89+MLM2+PRO&tag=${AMAZON_TAG}`, pr: true, description: '投球データを計測できるポータブルデバイス' },
];
---
<Layout title={pageTitle} description={description}>
  <style slot="head">
  .player-hero {
    background: var(--navy-dark, #0c1e33);
    color: #fff;
    padding: 3rem 0 2rem;
  }
  .player-hero .container {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .player-number {
    font-size: 0.9rem;
    opacity: 0.7;
    font-weight: 600;
  }
  .player-hero h1 {
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    font-weight: 800;
    margin: 0;
  }
  .player-position-badge {
    display: inline-block;
    background: rgba(255,255,255,0.15);
    padding: 0.2rem 0.75rem;
    border-radius: 20px;
    font-size: 0.85rem;
    font-weight: 600;
    width: fit-content;
  }
  .player-body { padding: 2rem 0 4rem; }
  .info-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 1rem;
    margin: 2rem 0;
  }
  .info-item {
    background: var(--gray-100, #f2f0ec);
    border: 1px solid var(--border, #e4e2dc);
    border-radius: 8px;
    padding: 1rem 1.1rem;
  }
  .info-label {
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--gray-500, #8a8680);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin: 0 0 0.25rem;
  }
  .info-value {
    font-size: 1rem;
    font-weight: 600;
    color: var(--text, #212529);
    margin: 0;
  }
  /* 成績カード */
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
    gap: 1rem;
    margin: 1.5rem 0 2rem;
  }
  .stat-card {
    background: var(--bg-card, #ffffff);
    border: 1px solid var(--border, #e4e2dc);
    border-radius: 10px;
    padding: 1.25rem 1rem;
    text-align: center;
    box-shadow: var(--shadow-sm);
    transition: box-shadow var(--transition);
  }
  .stat-card:hover {
    box-shadow: var(--shadow-md);
  }
  .stat-label {
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--gray-500, #8a8680);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin: 0 0 0.4rem;
  }
  .stat-value {
    font-size: 1.8rem;
    font-weight: 800;
    color: var(--navy, #152a42);
    margin: 0;
    line-height: 1;
    font-variant-numeric: tabular-nums;
    font-family: var(--font-en);
  }
  .stat-value.highlight {
    color: var(--accent, #9b2335);
  }
  .stat-sub {
    font-size: 0.75rem;
    color: var(--gray-400, #a8a49a);
    margin: 0.3rem 0 0;
  }
  .stats-team {
    font-size: 0.85rem;
    color: var(--gray-600, #6b6760);
    margin: 0 0 0.25rem;
  }
  .stats-asof {
    font-size: 0.75rem;
    color: var(--gray-500, #8a8680);
    margin: 0 0 1rem;
  }
  .stats-placeholder {
    background: var(--gray-100, #f2f0ec);
    border: 2px dashed var(--gray-200, #e4e2dc);
    border-radius: 8px;
    padding: 2rem 1.5rem;
    text-align: center;
    color: var(--gray-600, #6b6760);
    margin: 2rem 0;
  }
  .breadcrumb {
    font-size: 0.85rem;
    color: rgba(255,255,255,0.7);
    margin-bottom: 1rem;
  }
  .breadcrumb a { color: rgba(255,255,255,0.7); text-decoration: none; }
  .breadcrumb a:hover { color: #fff; }
  @media (max-width: 600px) {
    .info-grid { grid-template-columns: repeat(2, 1fr); gap: 0.75rem; }
    .stats-grid { grid-template-columns: repeat(2, 1fr); gap: 0.75rem; }
    .player-hero { padding: 2rem 0 1.5rem; }
    .player-body { padding: 1.5rem 0 3rem; }
  }
  @media (max-width: 380px) {
    .info-grid { grid-template-columns: 1fr; }
    .stats-grid { grid-template-columns: repeat(2, 1fr); }
    .info-item { padding: 0.875rem 1rem; }
    .player-hero h1 { font-size: 1.7rem; }
  }
  </style>

  <section class="player-hero">
    <div class="container">
      <nav class="breadcrumb" aria-label="パンくずリスト">
        <a href="/">Baseballab</a> &rsaquo; <a href="/players/">MLB選手</a> &rsaquo; {name}
      </nav>
      {number && <p class="player-number">{number}</p>}
      <h1>{name}</h1>
      <span class="player-position-badge">{position}</span>
    </div>
  </section>

  <div class="player-body">
    <div class="container">
      <AtomicAnswer text={atomicText} />

      <h2>プロフィール</h2>
      <div class="info-grid">
        {birthDate && (
          <div class="info-item">
            <p class="info-label">生年月日</p>
            <p class="info-value">{birthDate}{age ? ` (${age}歳)` : ''}</p>
          </div>
        )}
        {(birthCity || birthCountry) && (
          <div class="info-item">
            <p class="info-label">出身</p>
            <p class="info-value">{[birthCity, birthCountry].filter(Boolean).join(', ')}</p>
          </div>
        )}
        {height && (
          <div class="info-item">
            <p class="info-label">身長</p>
            <p class="info-value">{height}</p>
          </div>
        )}
        {weight && (
          <div class="info-item">
            <p class="info-label">体重</p>
            <p class="info-value">{weight}</p>
          </div>
        )}
        {bats && (
          <div class="info-item">
            <p class="info-label">打席</p>
            <p class="info-value">{bats}</p>
          </div>
        )}
        {throws && (
          <div class="info-item">
            <p class="info-label">投球腕</p>
            <p class="info-value">{throws}</p>
          </div>
        )}
        {debut && (
          <div class="info-item">
            <p class="info-label">MLBデビュー</p>
            <p class="info-value">{debut}</p>
          </div>
        )}
      </div>

      <h2>{SEASON_YEAR}年成績</h2>
      {teamName && <p class="stats-team">{teamName}</p>}
      <p class="stats-asof">MLB Stats API データ（{SEASON_YEAR}シーズン）</p>

      {isBatter && splitStat ? (
        <div class="stats-grid">
          {avg && (
              <div class="stat-card">
              <p class="stat-label">打率</p>
              <p class="stat-value">{avg}</p>
              <p class="stat-sub">AVG</p>
            </div>
          )}
          {hr !== null && (
            <div class="stat-card">
              <p class="stat-label">本塁打</p>
              <p class="stat-value highlight">{hr}</p>
              <p class="stat-sub">HR</p>
            </div>
          )}
          {rbi !== null && (
            <div class="stat-card">
              <p class="stat-label">打点</p>
              <p class="stat-value">{rbi}</p>
              <p class="stat-sub">RBI</p>
            </div>
          )}
          {ops && (
            <div class="stat-card">
              <p class="stat-label">OPS</p>
              <p class="stat-value">{ops}</p>
              <p class="stat-sub">出塁+長打</p>
            </div>
          )}
          {runs !== null && (
            <div class="stat-card">
              <p class="stat-label">得点 </p>
              <p class="stat-value">{runs}</p>
              <p class="stat-sub">R</p>
            </div>
          )}
          {hits !== null && (
            <div class="stat-card">
              <p class="stat-label">安打</p>
              <p class="stat-value">{hits}</p>
              <p class="stat-sub">H</p>
            </div>
          )}
          {sb !== null && sb > 0 && (
            <div class="stat-card">
              <p class="stat-label">盗塁</p>
              <p class="stat-value">{sb}</p>
              <p class="stat-sub">SB</p>
            </div>
          )}
          {gamesPlayed !== null && (
            <div class="stat-card">
              <p class="stat-label">試合</p>
              <p class="stat-value">{gamesPlayed}</p>
              <p class="stat-sub">G</p>
            </div>
          )}
        </div>
      ) : isPitcher && splitStat ? (
        <div class="stats-grid">
          {era && (
            <div class="stat-card">
              <p class="stat-label">防御率</p>
              <p class="stat-value highlight">{era}</p>
              <p class="stat-sub">ERA</p>
            </div>
          )}
          {wins !== null && losses !== null && (
            <div class="stat-card">
              <p class="stat-label">勝敗</p>
              <p class="stat-value">{wins}-{losses}</p>
              <p class="stat-sub">W-L</p>
            </div>
          )}
          {strikeOuts !== null && (
            <div class="stat-card">
              <p class="stat-label">奪三振</p>
              <p class="stat-value">{strikeOuts}</p>
              <p class="stat-sub">K</p>
            </div>
          )}
          {whip && (
            <div class="stat-card">
              <p class="stat-label">WHIP</p>
              <p class="stat-value">{whip}</p>
              <p class="stat-sub">BB+H/IP</p>
            </div>
          )}
          {ip && (
            <div class="stat-card">
              <p class="stat-label">投球回</p>
              <p class="stat-value">{ip}</p>
              <p class="stat-sub">IP</p>
            </div>
          )}
          {saves !== null && saves > 0 && (
            <div class="stat-card">
              <p class="stat-label">セーブ</p>
              <p class="stat-value">{saves}</p>
              <p class="stat-sub">SV</p>
            </div>
          )}
          {gamesPlayed !== null && (
            <div class="stat-card">
              <p class="stat-label">登板</p>
              <p class="stat-value">{gamesPlayed}</p>
              <p class="stat-sub">G</p>
            </div>
          )}
        </div>
      ) : (
        <div class="stats-placeholder">
          <p>📊 成績データは近日更新予定です。</p>
          <p style="font-size: 0.85rem; margin-top: 0.5rem;">MLB Stats API からの取得・整形を実施中。</p>
        </div>
      )}
      <AffiliateBlock links={affiliateLinks} heading="この選手をさらに知るためのおすすめ" />
</div>
  </div>
</Layout>
