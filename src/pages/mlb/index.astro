---

<Layout
  title="MLB データ分析 | Baseballab"
  description="MLBの選手成績・チーム分析データを網羅。大谷翔平・Aaron Judge等の注目選手30名とドジャース・ナンキース等の全30チームのデータを掲載。"
  ogUrl="https://baseballab.com/mlb/"
>
  <style slot="head">
    .hub-hero {
      background: linear-gradient(135deg, var(--navy-dark) 0%, var(--navy) 55%, #1a4a7a 100%);
      color: var(--white);
      padding: 4rem 1.25rem 3rem;
      text-align: center;
      position: relative;
      overflow: hidden;
    }
    .hub-hero::before {
      content: '🏟️';
      position: absolute;
      font-size: 18rem;
      opacity: 0.04;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      pointer-events: none;
      line-height: 1;
    }
    .hub-eyebrow {
      display: inline-block;
      background: rgba(192,57,43,0.85);
      color: var(--white);
      font-size: 0.78rem;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      padding: 0.3rem 0.9rem;
      border-radius: 9999px;
      margin-bottom: 1.25rem;
    }
    .hub-hero h1 {
      font-size: clamp(1.9rem, 4.5vw, 3rem);
      font-weight: 900;
      letter-spacing: -0.03em;
      line-height: 1.2;
      margin-bottom: 1rem;
    }
    .hub-hero h1 em { color: #7ec8e3; font-style: normal; }
    .hub-sub {
      font-size: clamp(0.9rem, 1.8vw, 1.05rem);
      color: rgba(255,255,255,0.78);
      max-width: 580px;
      margin: 0 auto 2rem;
      line-height: 1.75;
    }
    .hub-stats {
      display: flex;
      justify-content: center;
      gap: 2.5rem;
      flex-wrap: wrap;
    }
    .hub-stat { text-align: center; }
    .hub-stat-num {
      font-size: 2rem;
      font-weight: 900;
      color: #7ec8e3;
      line-height: 1;
      display: block;
    }
    .hub-stat-label {
      font-size: 0.78rem;
      color: rgba(255,255,255,0.6);
      margin-top: 0.2rem;
      letter-spacing: 0.05em;
    }

    .section { padding: 3.5rem 0; }
    .section-alt { background: var(--gray-100); }
    .section-header { margin-bottom: 2rem; }
    .section-label {
      display: inline-block;
      color: var(--red);
      font-size: 0.75rem;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      margin-bottom: 0.4rem;
    }
    .section-title {
      font-size: clamp(1.3rem, 2.8vw, 1.7rem);
      font-weight: 800;
      color: var(--navy);
      letter-spacing: -0.02em;
    }
    .section-lead {
      margin-top: 0.5rem;
      color: var(--gray-600);
      font-size: 0.9rem;
    }

    /* Featured player cards */
    .player-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
      gap: 1.25rem;
    }
    .player-card {
      background: var(--white);
      border: 1px solid var(--gray-200);
      border-radius: 12px;
      padding: 1.4rem 1.4rem 1.2rem;
      transition: box-shadow 0.2s, transform 0.2s;
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
      text-decoration: none;
      color: inherit;
    }
    .player-card:hover {
      box-shadow: 0 8px 24px rgba(26,58,92,0.13);
      transform: translateY(-3px);
    }
    .player-card-top {
      display: flex;
      align-items: center;
      gap: 0.75rem;
    }
    .player-avatar {
      width: 44px;
      height: 44px;
      border-radius: 50%;
      background: var(--navy);
      color: var(--white);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.3rem;
      flex-shrink: 0;
    }
    .player-meta { flex: 1; min-width: 0; }
    .player-name {
      font-size: 0.98rem;
      font-weight: 700;
      color: var(--navy-dark);
      line-height: 1.3;
    }
    .player-pos-team {
      font-size: 0.78rem;
      color: var(--gray-500);
      margin-top: 0.1rem;
    }
    .player-note {
      font-size: 0.8rem;
      color: var(--gray-600);
      line-height: 1.5;
      padding-top: 0.2rem;
      border-top: 1px solid var(--gray-100);
    }
    .player-link-hint {
      font-size: 0.78rem;
      color: var(--red);
      font-weight: 600;
      display: flex;
      align-items: center;
      gap: 0.25rem;
    }

    /* All players list */
    .player-list {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
      gap: 0.6rem;
    }
    .player-list-item {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      padding: 0.75rem 1rem;
      background: var(--white);
      border: 1px solid var(--gray-200);
      border-radius: 8px;
      text-decoration: none;
      color: inherit;
      transition: background 0.15s, box-shadow 0.15s;
      font-size: 0.87rem;
    }
    .player-list-item:hover {
      background: #f0f5ff;
      box-shadow: 0 2px 8px rgba(26,58,92,0.08);
    }
    .player-list-item .pos-badge {
      flex-shrink: 0;
      font-size: 0.68rem;
      font-weight: 700;
      color: var(--white);
      background: var(--navy);
      padding: 0.15rem 0.4rem;
      border-radius: 4px;
      letter-spacing: 0.04em;
    }
    .player-list-item .player-list-name {
      flex: 1;
      font-weight: 600;
      color: var(--navy-dark);
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .player-list-item .team-tag {
      flex-shrink: 0;
      font-size: 0.72rem;
      color: var(--gray-400);
    }

    /* Division grid */
    .division-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
      gap: 1.5rem;
    }
    .division-card {
      background: var(--white);
      border: 1px solid var(--gray-200);
      border-radius: 12px;
      overflow: hidden;
    }
    .division-header {
      background: var(--navy);
      color: var(--white);
      padding: 0.65rem 1.1rem;
      font-size: 0.82rem;
      font-weight: 700;
      letter-spacing: 0.06em;
      text-transform: uppercase;
    }
    .division-header.al { background: #c0392b; }
    .division-header.nl { background: #1a5276; }
    .team-link {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      padding: 0.65rem 1.1rem;
      text-decoration: none;
      color: inherit;
      border-bottom: 1px solid var(--gray-100);
      transition: background 0.15s;
      font-size: 0.88rem;
    }
    .team-link:last-child { border-bottom: none; }
    .team-link:hover { background: #f0f5ff; }
    .team-abbr {
      flex-shrink: 0;
      font-size: 0.72rem;
      font-weight: 700;
      color: var(--white);
      background: var(--navy);
      padding: 0.15rem 0.45rem;
      border-radius: 4px;
      min-width: 36px;
      text-align: center;
      letter-spacing: 0.03em;
    }
    .team-name-text {
      flex: 1;
      font-weight: 600;
      color: var(--navy-dark);
    }
    .team-arrow {
      color: var(--gray-300);
      font-size: 0.9rem;
      transition: color 0.15s, transform 0.15s;
    }
    .team-link:hover .team-arrow {
      color: var(--red);
      transform: translateX(3px);
    }

    /* Breadcrumb */
    .breadcrumb {
      padding: 0.75rem 0;
      font-size: 0.8rem;
      color: var(--gray-500);
    }
    .breadcrumb a { color: var(--gray-500); text-decoration: none; }
    .breadcrumb a:hover { color: var(--navy); }
    .breadcrumb span { margin: 0 0.4rem; }

    @media (max-width: 768px) {
      .hub-hero { padding: 3rem 1.25rem 2.5rem; }
      .hub-hero::before { font-size: 10rem; }
      .hub-stats { gap: 1.5rem; }
      .section { padding: 2.5rem 0; }
      .player-grid { grid-template-columns: 1fr 1fr; }
      .player-list { grid-template-columns: 1fr; }
    }
    @media (max-width: 480px) {
      .hub-hero { padding: 2.5rem 0 2rem; }
      .hub-stat-num { font-size: 1.6rem; }
      .player-grid { grid-template-columns: 1fr; }
      .player-card { padding: 1.25rem; }
      .division-grid { grid-template-columns: 1fr; }
      .division-header { padding: 0.6rem 1rem; }
      .division-row { padding: 0.6rem 1rem; }
      .section { padding: 2rem 0; }
      .section-header h2 { font-size: 1.3rem; }
    }

    /* ===== LEADERS BANNER ===== */
    .leaders-banner {
      display: flex;
      align-items: center;
      gap: 1rem;
      background: linear-gradient(135deg, var(--navy) 0%, var(--navy-dark) 100%);
      color: var(--white);
      border-radius: 12px;
      padding: 1.25rem 1.5rem;
      text-decoration: none;
      transition: transform 0.15s, box-shadow 0.15s;
      box-shadow: 0 4px 16px rgba(26,58,92,0.25);
    }
    .leaders-banner:hover {
      transform: translateY(-2px);
      box-shadow: 0 6px 20px rgba(26,58,92,0.35);
    }
    .leaders-banner-icon { font-size: 2rem; flex-shrink: 0; }
    .leaders-banner-body { flex: 1; }
    .leaders-banner-title {
      font-size: 1.1rem;
      font-weight: 700;
      margin-bottom: 0.25rem;
    }
    .leaders-banner-sub {
      font-size: 0.85rem;
      opacity: 0.8;
    }
    .leaders-banner-arrow {
      font-size: 1.4rem;
      opacity: 0.7;
      flex-shrink: 0;
    }
  </style>

  <!-- Hero -->
  <section class="hub-hero">
    <div class="container">
      <p class="hub-eyebrow">⚾ MLB Data Analysis</p>
      <h1>MLB データ分析<br><em>ハブページ</em></h1>
      <p class="hub-sub">メジャーリーグ全30チーム・注目選手のデータを網羅。<br>成績・プロフィール・セイバーメトリクスまで、最新データをチェック。</p>
      <div class="hub-stats">
        <div class="hub-stat">
          <span class="hub-stat-num">30</span>
          <div class="hub-stat-label">選手データ</div>
        </div>
        <div class="hub-stat">
          <span class="hub-stat-num">30</span>
          <div class="hub-stat-label">チームデータ</div>
        </div>
        <div class="hub-stat">
          <span class="hub-stat-num">6</span>
          <div class="hub-stat-label">ディビジョン</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Breadcrumb -->
  <div class="container">
    <nav class="breadcrumb" aria-label="パンくずリスト">
      <a href="/">トップ</a>
      <span>›</span>
      <span>MLB データ分析</span>
    </nav>
  </div>


  <!-- Leaders Banner -->
  <section class="section" style="padding:1.5rem 0 0;">
    <div class="container">
      <a href="/mlb/leaders/" class="leaders-banner">
        <div class="leaders-banner-icon">📊</div>
        <div class="leaders-banner-body">
          <div class="leaders-banner-title">MLB 2025 成績ランキング</div>
          <div class="leaders-banner-sub">ホームラン・打率・打点・防御率など、2025年シーズン最新リーダーボード</div>
        </div>
        <div class="leaders-banner-arrow">→</div>
      </a>
    </div>
  </section>

  <!-- Featured Players -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <p class="section-label">⭐ 注目選手</p>
        <h2 class="section-title">フィーチャード・プレイヤー</h2>
        <p class="section-lead">今注目のMLB選手のデータ・プロフィールをチェック</p>
      </div>
      <div class="player-grid">
        {featuredPlayers.map(p => (
          <a href={`/players/${p.slug}/`} class="player-card">
            <div class="player-card-top">
              <div class="player-avatar">⚾</div>
              <div class="player-meta">
                <div class="player-name">{p.name}</div>
                <div class="player-pos-team">{p.pos} · {p.team}</div>
              </div>
            </div>
            <div class="player-note">{p.note}</div>
            <div class="player-link-hint">詳細データを見る →</div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- All Players -->
  <section class="section section-alt">
    <div class="container">
      <div class="section-header">
        <p class="section-label">📋 全選手一覧</p>
        <h2 class="section-title">選手データ一覧（30名）</h2>
        <p class="section-lead">掲載中の全選手のプロフィール・成績データ</p>
      </div>
      <div class="player-list">
        {allPlayers.map(p => (
          <a href={`/players/${p.slug}/`} class="player-list-item">
            <span class="pos-badge">{p.pos}</span>
            <span class="player-list-name">{p.name}</span>
            <span class="team-tag">{p.team}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Teams by Division -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <p class="section-label">🏟️ チーム別データ</p>
        <h2 class="section-title">全30チーム — ディビジョン別</h2>
        <p class="section-lead">各チームの詳細データ・ロスター・成績を確認</p>
      </div>
      <div class="division-grid">
        {divisions.map(div => (
          <div class="division-card">
            <div class={`division-header ${div.name.startsWith('AL') ? 'al' : 'nl'}`}>
              {div.name}
            </div>
            {div.teams.map(t => (
              <a href={`/teams/${t.slug}/`} class="team-link">
                <span class="team-abbr">{t.abbr}</span>
                <span class="team-name-text">{t.name}</span>
                <span class="team-arrow">›</span>
              </a>
            ))}
          </div>
        ))}
      </div>
    </div>
  </section>

</Layout>
