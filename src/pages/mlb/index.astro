    name: 'NL West', teams: [
      { slug: 'arizona-diamondbacks', name: 'Arizona Diamondbacks', abbr: 'ARI' },
      { slug: 'colorado-rockies',     name: 'Colorado Rockies',     abbr: 'COL' },
      { slug: 'los-angeles-dodgers',  name: 'Los Angeles Dodgers',  abbr: 'LAD' },
      { slug: 'san-diego-padres',     name: 'San Diego Padres',     abbr: 'SD' },
      { slug: 'san-francisco-giants', name: 'San Francisco Giants', abbr: 'SF' },
    ]
