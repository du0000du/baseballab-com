---
// /mlb/ — MLB データ分析ハブ
import Layout from '../../layouts/Layout.astro';

const SEASON = '2026';

const features = [
  {
    icon: '📊',
    title: 'リーダーボード',
    desc: '打率・本塁打・打点・防御率・奪三振など各部門のリーディングハイターをランキング形式で掲載。',
    href: '/mlb/leaders/',
    label: 'ランキングを見る',
  },
  {
    icon: '👤',
    title: '選手成績',
    desc: 'OPS・WAR・FIP・wRC+などセイバーメトリクス指標で主要選手の成績を分析。大谷翔平ほか注目選手のデータも。',
    href: '/players/',
    label: '選手データを見る',
  },
  {
    icon: '🏟️',
    title: 'チーム成績',
    desc: 'MLB全30球団の打撃・投球・守備成績。地区別ランキングとシーズン成績を掲載。',
    href: '/teams/',
    label: 'チーム一覧へ',
  },
  {
    icon: '📈',
    title: 'シーズントレンド',
    desc: '2026シーズンの月別・週別成績推移。ホットストリーク・スランプを可視化。',
    href: '/season/',
    label: 'シーズンデータへ',
  },
];

const spotlightPlayers = [
  { name: '大谷 翔平', nameEn: 'Shohei Ohtani', team: 'Los Angeles Dodgers', note: '2024 MVP・本塁打王', slug: 'shohei-ohtani' },
  { name: '山本 由伸', nameEn: 'Yoshinobu Yamamoto', team: 'Los Angeles Dodgers', note: 'エース右腕', slug: 'yoshinobu-yamamoto' },
  { name: '今永 昇太', nameEn: 'Shota Imanaga', team: 'Chicago Cubs', note: '2024新人王', slug: 'shota-imanaga' },
  { name: '吉田 正尚', nameEn: 'Masataka Yoshida', team: 'Boston Red Sox', note: '高打率の巧打者', slug: 'masataka-yoshida' },
];
---

<Layout
  title={`MLB データ分析 ${SEASON} | 選手・チーム成績 | Baseballab`}
  description={`MLB ${SEASON}シーズンの選手成績・チーム成績・リーダーボードを掲載。大谷翔平ほか日本人選手のStatcastデータも。セイバーメトリクスで野球を深く読む。`}
  ogUrl="https://baseballab.com/mlb/"
>
  <style slot="head">
    .mlb-hero {
      background: linear-gradient(135deg, var(--navy-dark) 0%, var(--navy) 55%, #1a4a7a 100%);
      color: var(--white);
      padding: 3.5rem 1.25rem 2.75rem;
      text-align: center;
    }
    .mlb-eyebrow {
      display: inline-block;
      background: rgba(192,57,43,.85);
      font-size: .75rem;
      font-weight: 700;
      letter-spacing: .1em;
      text-transform: uppercase;
      padding: .3rem .9rem;
      border-radius: 9999px;
      margin-bottom: 1rem;
    }
    .mlb-hero h1 {
      font-size: clamp(1.8rem, 4.5vw, 2.9rem);
      font-weight: 900;
      letter-spacing: -.03em;
      line-height: 1.2;
      margin-bottom: .85rem;
    }
    .mlb-hero h1 em { color: #7ec8e3; font-style: normal; }
    .mlb-sub {
      color: rgba(255,255,255,.8);
      max-width: 600px;
      margin: 0 auto 1.75rem;
      line-height: 1.75;
      font-size: clamp(.9rem, 1.8vw, 1.02rem);
    }
    .mlb-stats { display: flex; justify-content: center; gap: 2.5rem; flex-wrap: wrap; }
    .stat-num { font-size: 2rem; font-weight: 900; color: #7ec8e3; display: block; line-height: 1; }
    .stat-label { font-size: .78rem; color: rgba(255,255,255,.6); margin-top: .2rem; }
    .breadcrumb { padding: .75rem 0; font-size: .8rem; color: var(--gray-500); }
    .breadcrumb a { color: var(--gray-500); }
    .breadcrumb span { margin: 0 .4rem; }
    .section { padding: 3rem 0; }
    .section-alt { background: var(--gray-100); }
    .section-label { display: inline-block; color: var(--red); font-size: .75rem; font-weight: 700; letter-spacing: .12em; text-transform: uppercase; margin-bottom: .4rem; }
    .section-title { font-size: clamp(1.3rem, 2.8vw, 1.7rem); font-weight: 800; color: var(--navy); letter-spacing: -.02em; }
    .section-lead { margin-top: .5rem; color: var(--gray-600); font-size: .9rem; }
    .section-header { margin-bottom: 1.75rem; }
    .feature-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      gap: 1.25rem;
    }
    .feature-card {
      background: var(--white);
      border: 1px solid var(--gray-200);
      border-radius: 12px;
      padding: 1.6rem 1.4rem;
      display: flex;
      flex-direction: column;
      gap: .65rem;
      transition: box-shadow .2s, transform .2s;
    }
    .feature-card:hover { box-shadow: 0 8px 24px rgba(26,58,92,.12); transform: translateY(-3px); }
    .fc-icon { font-size: 1.9rem; line-height: 1; }
    .fc-title { font-size: 1.02rem; font-weight: 700; color: var(--navy); }
    .fc-desc { font-size: .86rem; color: var(--gray-600); line-height: 1.65; flex: 1; }
    .fc-link { display: inline-flex; align-items: center; gap: .3rem; color: var(--red); font-size: .84rem; font-weight: 600; margin-top: .2rem; transition: gap .15s; }
    .fc-link:hover { gap: .55rem; }
    .spotlight-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
      gap: 1rem;
    }
    .player-card {
      background: var(--white);
      border: 1px solid var(--gray-200);
      border-radius: 10px;
      padding: 1.2rem;
      display: flex;
      flex-direction: column;
      gap: .5rem;
      transition: box-shadow .2s, transform .2s;
    }
    .player-card:hover { box-shadow: 0 6px 18px rgba(26,58,92,.12); transform: translateY(-2px); }
    .player-avatar {
      width: 44px; height: 44px; border-radius: 50%;
      background: var(--navy); color: var(--white);
      display: flex; align-items: center; justify-content: center;
      font-size: 1.3rem;
    }
    .player-name { font-weight: 700; color: var(--navy-dark); font-size: .95rem; line-height: 1.3; }
    .player-en { font-size: .78rem; color: var(--gray-400); }
    .player-team { font-size: .8rem; color: var(--gray-600); }
    .player-note { font-size: .8rem; color: var(--red); font-weight: 600; }
    .player-link { font-size: .78rem; color: var(--navy); font-weight: 600; margin-top: auto; }
    .player-link:hover { color: var(--red); }
    .leaders-banner {
      display: flex; align-items: center; gap: 1rem;
      background: linear-gradient(135deg, var(--navy) 0%, var(--navy-dark) 100%);
      color: var(--white); border-radius: 12px; padding: 1.25rem 1.5rem;
      box-shadow: 0 4px 12px rgba(15,37,64,.3);
      transition: transform .2s;
    }
    .leaders-banner:hover { transform: translateY(-2px); }
    .lb-icon { font-size: 2rem; }
    .lb-body { flex: 1; }
    .lb-title { font-size: 1.05rem; font-weight: 700; margin-bottom: .25rem; }
    .lb-sub { font-size: .85rem; opacity: .8; }
    .lb-arrow { font-size: 1.4rem; opacity: .7; }
    .npb-link-banner {
      margin-top: 1.5rem;
      display: flex; align-items: center; gap: 1rem;
      background: linear-gradient(135deg, #9b2335 0%, #7d1c2a 100%);
      color: var(--white); border-radius: 12px; padding: 1.1rem 1.5rem;
      transition: transform .2s;
    }
    .npb-link-banner:hover { transform: translateY(-2px); }
    @media (max-width: 768px) { .spotlight-grid { grid-template-columns: 1fr 1fr; } }
    @media (max-width: 480px) { .spotlight-grid { grid-template-columns: 1fr; } }
  </style>

  <!-- HERO -->
  <section class="mlb-hero">
    <div class="container">
      <p class="mlb-eyebrow">⚾ MLB Data Analysis</p>
      <h1>MLB <em>{SEASON}</em><br>データ分析ハブ</h1>
      <p class="mlb-sub">メジャーリーグ {SEASON}シーズンの選手成績・チーム成績・リーダーボードをセイバーメトリクスで深掘り。</p>
      <div class="mlb-stats">
        <div><span class="stat-num">30</span><div class="stat-label">球団</div></div>
        <div><span class="stat-num">9+</span><div class="stat-label">成績部門</div></div>
        <div><span class="stat-num">毎日</span><div class="stat-label">データ更新</div></div>
      </div>
    </div>
  </section>

  <div class="container">
    <nav class="breadcrumb"><a href="/">トップ</a><span>›</span><span>MLB データ分析</span></nav>
  </div>

  <!-- リーダーボードバナー -->
  <section class="section" style="padding: 0 0 1rem;">
    <div class="container">
      <a href="/mlb/leaders/" class="leaders-banner">
        <div class="lb-icon">📊</div>
        <div class="lb-body">
          <div class="lb-title">MLB {SEASON} 成績ランキング</div>
          <div class="lb-sub">打率・本塁打・打点・防御率・奪三振など各部門のリーダーボード</div>
        </div>
        <div class="lb-arrow">→</div>
      </a>
    </div>
  </section>

  <!-- 機能カード -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <p class="section-label">Features</p>
        <h2 class="section-title">MLBデータでできること</h2>
        <p class="section-lead">セイバーメトリクスを使った深い分析で、野球観戦がもっと楽しくなる</p>
      </div>
      <div class="feature-grid">
        {features.map(f => (
          <div class="feature-card">
            <div class="fc-icon">{f.icon}</div>
            <div class="fc-title">{f.title}</div>
            <p class="fc-desc">{f.desc}</p>
            <a href={f.href} class="fc-link">{f.label} →</a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 注目選手 -->
  <section class="section section-alt">
    <div class="container">
      <div class="section-header">
        <p class="section-label">Spotlight</p>
        <h2 class="section-title">注目の日本人選手</h2>
        <p class="section-lead">MLB で活躍する日本人選手の成績データ</p>
      </div>
      <div class="spotlight-grid">
        {spotlightPlayers.map(p => (
          <div class="player-card">
            <div class="player-avatar">⚾</div>
            <div class="player-name">{p.name}</div>
            <div class="player-en">{p.nameEn}</div>
            <div class="player-team">{p.team}</div>
            <div class="player-note">{p.note}</div>
            <a href={`/mlb/players/${p.slug}/`} class="player-link">成績データを見る →</a>
          </div>
        ))}
      </div>

      <a href="/npb/" class="npb-link-banner">
        <div style="font-size:1.5rem">🇯🇵</div>
        <div style="flex:1">
          <div style="font-weight:700;margin-bottom:.2rem">NPBデータはこちら — セ・パ12球団</div>
          <div style="font-size:.85rem;opacity:.8">2026シーズン最新成績・87選手データを毎日更新</div>
        </div>
        <div style="font-size:1.4rem;opacity:.7">→</div>
      </a>
    </div>
  </section>
</Layout>
