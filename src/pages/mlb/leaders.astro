---
// src/pages/mlb/leaders.astro
// MLB シーズン成績リーダーボード
// SEASON シーズン判定: 3月以降は当年、1〜2月は前年（オフシーズン）。env MLB_SEASON で上書き可
// データはビルド時にMLB Stats APIから直接取得

import Layout from '../../layouts/Layout.astro';

// シーズン判定: 3月以降は当年、1〜2月はオフシーズン扱いで前年。MLB_SEASON envで上書き可
const SEASON = String(process.env.MLB_SEASON || (new Date().getMonth() + 1 >= 3 ? new Date().getFullYear() : new Date().getFullYear() - 1));
const BASE = 'https://statsapi.mlb.com/api/v1';

async function getLeaders(group, sortStat, limit = 10) {
  try {
    const url = `${BASE}/stats?stats=season&season=${SEASON}&group=${group}&sortStat=${sortStat}&limit=${limit}&gameType=R&hydrate=person,team`;
    const res = await fetch(url);
    if (!res.ok) return [];
    const json = await res.json();
    const splits = json?.stats?.[0]?.splits ?? [];
    return splits.map((item, i) => ({
      rank: item.rank ?? (i + 1),
      player: item.player?.fullName ?? '—',
      team: item.team?.abbreviation ?? item.team?.teamName ?? '—',
      value: item.stat?.[sortStat] ?? '—',
    }));
  } catch (e) {
    return [];
  }
}

const [hrLeaders, avgLeaders, rbiLeaders, sbLeaders] = await Promise.all([
  getLeaders('hitting', 'homeRuns'),
  getLeaders('hitting', 'avg'),
  getLeaders('hitting', 'rbi'),
  getLeaders('hitting', 'stolenBases'),
]);

const [eraLeaders, wLeaders, soLeaders, svLeaders] = await Promise.all([
  getLeaders('pitching', 'era'),
  getLeaders('pitching', 'wins'),
  getLeaders('pitching', 'strikeOuts'),
  getLeaders('pitching', 'saves'),
]);

const battingCategories = [
  { label: 'ホームラン（HR）', leaders: hrLeaders },
  { label: '打率（AVG）',      leaders: avgLeaders },
  { label: '打点（RBI）',      leaders: rbiLeaders },
  { label: '盗塁（SB）',       leaders: sbLeaders },
];

const pitchingCategories = [
  { label: '防御率（ERA）',  leaders: eraLeaders },
  { label: '勝利（W）',      leaders: wLeaders },
  { label: '奪三振（SO）',   leaders: soLeaders },
  { label: 'セーブ（SV）',   leaders: svLeaders },
];

const MEDALS = ['🥇', '🥈', '🥉'];

const buildDate = new Date().toLocaleDateString('ja-JP', {
  year: 'numeric', month: 'long', day: 'numeric', timeZone: 'Asia/Tokyo'
});
const hasData = hrLeaders.length > 0 || eraLeaders.length > 0;
---

<Layout
  title={`MLB ${SEASON} 成績ランキング | Baseballab`}
  description={`MLB ${SEASON}シーズン最新成績ランキング。ホームラン・打率・打点・防御率・奪三振など全部門のリーダーボード。毎日自動更新。`}
  ogUrl="https://baseballab.com/mlb/leaders/"
  ogType="website"
>
  <style slot="head">
    /* ===== LEADERS PAGE ===== */
    .leaders-hero {
      background: linear-gradient(135deg, var(--navy) 0%, var(--navy-dark) 100%);
      color: var(--white);
      padding: 3rem 0 2.5rem;
    }
    .breadcrumb {
      font-size: 0.8rem;
      opacity: 0.65;
      margin-bottom: 1rem;
    }
    .breadcrumb a { color: inherit; }
    .breadcrumb a:hover { text-decoration: underline; opacity: 0.9; }

    .leaders-hero h1 {
      font-size: clamp(1.5rem, 4vw, 2.2rem);
      font-weight: 800;
      margin-bottom: 0.5rem;
      line-height: 1.2;
    }
    .hero-sub {
      font-size: 1rem;
      opacity: 0.8;
      margin-bottom: 0.75rem;
    }
    .updated-badge {
      display: inline-flex;
      align-items: center;
      gap: 0.3rem;
      background: rgba(255,255,255,0.12);
      border: 1px solid rgba(255,255,255,0.2);
      border-radius: 20px;
      padding: 0.25rem 0.9rem;
      font-size: 0.78rem;
    }

    /* ===== SECTIONS ===== */
    .leaders-section {
      padding: 3rem 0;
      background: var(--gray-100, #f5f5f3);
    }
    .section-title {
      font-size: 1.2rem;
      font-weight: 700;
      color: var(--navy);
      margin-bottom: 1.5rem;
      padding-bottom: 0.5rem;
      border-bottom: 2px solid var(--navy);
      display: flex;
      align-items: center;
      gap: 0.4rem;
    }

    /* ===== GRID ===== */
    .leaders-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 1.25rem;
    }

    /* ===== CARD ===== */
    .leaders-card {
      background: var(--white, #fff);
      border-radius: 10px;
      overflow: hidden;
      box-shadow: 0 1px 6px rgba(0,0,0,0.08);
      border: 1px solid rgba(22,45,71,0.1);
    }
    .card-title {
      background: var(--navy);
      color: var(--white);
      font-size: 0.9rem;
      font-weight: 600;
      padding: 0.6rem 1rem;
      letter-spacing: 0.01em;
    }

    /* ===== TABLE ===== */
    .leaders-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 0.87rem;
    }
    .leaders-table thead {
      background: rgba(22,45,71,0.04);
    }
    .leaders-table th {
      padding: 0.4rem 0.75rem;
      text-align: left;
      font-weight: 600;
      color: var(--gray-600, #6b7280);
      font-size: 0.7rem;
      text-transform: uppercase;
      letter-spacing: 0.06em;
    }
    .leaders-table th:last-child { text-align: right; padding-right: 1rem; }
    .leaders-table tbody tr {
      border-bottom: 1px solid rgba(0,0,0,0.06);
      transition: background 0.1s;
    }
    .leaders-table tbody tr:hover { background: rgba(22,45,71,0.03); }
    .leaders-table tbody tr:last-child { border-bottom: none; }
    .leaders-table td {
      padding: 0.5rem 0.75rem;
      vertical-align: middle;
    }

    /* rank — medal emoji for top 3, plain number otherwise */
    td.rank {
      width: 2.4rem;
      text-align: center;
      font-size: 1rem;
      line-height: 1;
    }
    td.rank.rank-num {
      font-size: 0.78rem;
      font-weight: 600;
      color: var(--gray-400, #9ca3af);
    }

    td.player-name {
      font-weight: 600;
      color: var(--text, #1a1a2e);
    }
    td.team {
      font-size: 0.73rem;
      color: var(--gray-600, #6b7280);
      white-space: nowrap;
    }
    td.stat-val {
      font-weight: 700;
      color: var(--navy);
      text-align: right;
      padding-right: 1rem;
      font-size: 0.92rem;
      white-space: nowrap;
      font-variant-numeric: tabular-nums;
    }
    td.no-data {
      text-align: center;
      color: var(--gray-400, #9ca3af);
      padding: 2rem;
      font-style: italic;
      font-size: 0.85rem;
    }

    /* ===== DATA NOTE ===== */
    .data-note {
      padding: 1.75rem 0;
      background: var(--gray-100, #f5f5f3);
      border-top: 1px solid rgba(0,0,0,0.08);
    }
    .data-note p {
      font-size: 0.8rem;
      color: var(--gray-600, #6b7280);
      text-align: center;
      line-height: 1.8;
    }

    /* ===== RESPONSIVE ===== */
    @media (max-width: 768px) {
      .leaders-grid { grid-template-columns: 1fr; }
    }
    @media (max-width: 480px) {
      .leaders-hero { padding: 2rem 0 1.75rem; }
      .leaders-section { padding: 2rem 0; }
      .section-title { font-size: 1.05rem; }
    }
  </style>

  <main>

    <!-- HERO -->
    <section class="leaders-hero">
      <div class="container">
        <nav class="breadcrumb" aria-label="パンくずリスト">
          <a href="/">Home</a> &rsaquo;
          <a href="/mlb/">MLB</a> &rsaquo;
          <span>成績ランキング</span>
        </nav>
        <script type="application/ld+json" set:html={JSON.stringify({
          "@context": "https://schema.org",
          "@type": "BreadcrumbList",
          "itemListElement": [
            { "@type": "ListItem", "position": 1, "name": "Baseballab", "item": "https://baseballab.com/" },
            { "@type": "ListItem", "position": 2, "name": "MLB", "item": "https://baseballab.com/mlb/" },
            { "@type": "ListItem", "position": 3, "name": "成績ランキング" }
          ]
        })} />
        <h1>📊 MLB {SEASON} 成績ランキング</h1>
        <p class="hero-sub">{SEASON}シーズン最終成績リーダーボード</p>
        <span class="updated-badge">🔄 {buildDate} 更新</span>
      </div>
    </section>

    <!-- BATTING SECTION -->
    <section class="leaders-section">
      <div class="container">
        <h2 class="section-title">🏏 打撃部門</h2>
        {!hasData && (
          <p style="color:var(--gray-600);padding:2rem 0;">データを取得中です。しばらくお待ちください。</p>
        )}
        <div class="leaders-grid">
          {battingCategories.map(cat => (
            <div class="leaders-card">
              <h3 class="card-title">{cat.label}</h3>
              <table class="leaders-table">
                <thead>
                  <tr>
                    <th></th>
                    <th>選手名</th>
                    <th>チーム</th>
                    <th>記録</th>
                  </tr>
                </thead>
                <tbody>
                  {cat.leaders.length > 0 ? cat.leaders.map(p => (
                    <tr>
                      <td class={p.rank <= 3 ? 'rank' : 'rank rank-num'}>
                        {p.rank <= 3 ? MEDALS[p.rank - 1] : p.rank}
                      </td>
                      <td class="player-name">{p.player}</td>
                      <td class="team">{p.team}</td>
                      <td class="stat-val">{p.value}</td>
                    </tr>
                  )) : (
                    <tr>
                      <td colspan="4" class="no-data">データ取得中...</td>
                    </tr>
                  )}
                </tbody>
              </table>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- PITCHING SECTION -->
    <section class="leaders-section" style="background:var(--white,#fff);">
      <div class="container">
        <h2 class="section-title">⚾ 投球部門</h2>
        <div class="leaders-grid">
          {pitchingCategories.map(cat => (
            <div class="leaders-card">
              <h3 class="card-title">{cat.label}</h3>
              <table class="leaders-table">
                <thead>
                  <tr>
                    <th></th>
                    <th>選手名</th>
                    <th>チーム</th>
                    <th>記録</th>
                  </tr>
                </thead>
                <tbody>
                  {cat.leaders.length > 0 ? cat.leaders.map(p => (
                    <tr>
                      <td class={p.rank <= 3 ? 'rank' : 'rank rank-num'}>
                        {p.rank <= 3 ? MEDALS[p.rank - 1] : p.rank}
                      </td>
                      <td class="player-name">{p.player}</td>
                      <td class="team">{p.team}</td>
                      <td class="stat-val">{p.value}</td>
                    </tr>
                  )) : (
                    <tr>
                      <td colspan="4" class="no-data">データ取得中...</td>
                    </tr>
                  )}
                </tbody>
              </table>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- DATA NOTE -->
    <div class="data-note">
      <div class="container">
        <p>
          データ出典: <a href="https://statsapi.mlb.com" style="color:var(--navy);">MLB Stats API</a>（公式）&nbsp;／&nbsp;
          レギュラーシーズン成績（{SEASON}年）のみ対象&nbsp;／&nbsp;
          毎日 JST 06:00 頃に自動更新
        </p>
      </div>
    </div>

  </main>
</Layout>
