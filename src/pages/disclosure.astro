---
// src/pages/disclosure.astro
// TASK-017: 広告・アフィリエイト開示ページ（ステマ規制対応）
import Layout from '../layouts/Layout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
---

<Layout
  title="広告・アフィリエイトについて | Baseballab"
  description="Baseballabの広告ポリシーおよびアフィリエイト参加プログラムの開示。2023年10月施行のステマ規制に対応した広告表示方針を掲載しています。"
  ogUrl="https://baseballab.com/disclosure/"
>
  <div class="disclosure-page">
    <Breadcrumb items={[
      { label: 'ホーム', href: '/' },
      { label: '広告・アフィリエイトについて' },
    ]} />

    <h1>広告・アフィリエイトについて</h1>

    <section>
      <h2>本サイトの広告について</h2>
      <p>
        Baseballab（本サイト）には、アフィリエイト広告が含まれます。
        読者の皆様に明示するため、広告リンクには「PR」バッジを表示しています。
      </p>
      <p>
        アフィリエイト収益は、サイトの運営・コンテンツ制作費に充てられます。
        掲載商品・サービスの選定は編集方針に基づいており、広告主からの依頼によって内容を変更することはありません。
      </p>
    </section>

    <section>
      <h2>参加しているアフィリエイトプログラム</h2>
      <ul>
        <li>
          <strong>Amazonアソシエイト</strong> —
          Amazonアソシエイト・プログラムの参加者です。適格販売により収入を得ることがあります。
        </li>
        <li>
          <strong>楽天アフィリエイト</strong>（参加予定）
        </li>
      </ul>
    </section>

    <section>
      <h2>Google AdSenseについて</h2>
      <p>
        本サイトはGoogle AdSenseを使用しています。
        GoogleはCookieを使用し、サイト訪問者に関連性の高い広告を表示することがあります。
        詳細は<a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">Googleプライバシーポリシー</a>をご参照ください。
      </p>
    </section>

    <section>
      <h2>お問い合わせ</h2>
      <p>広告に関するお問い合わせは <a href="mailto:contact@baseballab.com">contact@baseballab.com</a> までご連絡ください。</p>
    </section>

    <p class="updated">最終更新: 2026年5月19日</p>
  </div>
</Layout>

<style>
  .disclosure-page {
    max-width: 760px;
    margin: 0 auto;
    padding: 1.5rem 1rem;
  }
  h1 { font-size: 1.6rem; margin-bottom: 1.5rem; }
  section { margin-bottom: 2rem; }
  h2 {
    font-size: 1.1rem;
    border-left: 4px solid var(--navy, #1a2744);
    padding-left: 0.75rem;
    margin-bottom: 0.75rem;
    color: var(--navy, #1a2744);
  }
  p { line-height: 1.8; margin-bottom: 0.75rem; }
  ul { padding-left: 1.5rem; line-height: 1.8; }
  li { margin-bottom: 0.5rem; }
  a { color: var(--navy, #1a2744); }
  .updated { font-size: 0.8rem; color: #888; margin-top: 3rem; }
</style>