---
import Layout from '../../../../layouts/Layout.astro';
import AffiliateBlock from '../../../../components/AffiliateBlock.astro';
import { loadPlayers, NPB_SEASON } from '../../../../lib/npb';

export async function getStaticPaths() {
  return loadPlayers().map(p => ({ params: { slug: p.slug }, props: { p } }));
}
const { p } = Astro.props;
const s = p.stats || {};
const isBat   = p.group === 'batting';
const leagueEn = p.league === 'central' ? 'Central League' : 'Pacific League';

let snip = '';
if (isBat) {
  const parts: string[] = [];
  if (s.avg  != null) parts.push(`AVG ${s.avg}`);
  if (s.hr   != null) parts.push(`${s.hr} HR`);
  if (s.rbi  != null) parts.push(`${s.rbi} RBI`);
  if (s.ops  != null) parts.push(`OPS ${s.ops}`);
  snip = parts.length ? `In ${NPB_SEASON}: ${parts.join(' · ')}.` : '';
} else {
  const parts: string[] = [];
  if (s.wins != null) parts.push(`${s.wins}W-${s.losses??0}L`);
  if (s.era  != null) parts.push(`ERA ${s.era}`);
  if (s.so   != null) parts.push(`${s.so} SO`);
  if (s.saves) parts.push(`${s.saves} SV`);
  snip = parts.length ? `In ${NPB_SEASON}: ${parts.join(' · ')}.` : '';
}

const batCards: [string, any, string, boolean][] = [
  ['Batting Avg', s.avg, 'AVG', true], ['Home Runs', s.hr, 'HR', false], ['RBI', s.rbi, 'RBI', false],
  ['OPS', s.ops, 'OBP+SLG', false], ['Hits', s.hits, 'H', false], ['Runs', s.runs, 'R', false],
  ['Stolen Bases', s.sb, 'SB', false], ['OBP', s.obp, 'OBP', false], ['SLG', s.slg, 'SLG', false], ['Games', s.games, 'G', false],
];
const pitCards: [string, any, string, boolean][] = [
  ['ERA', s.era, 'ERA', true], ['Record', (s.wins != null ? `${s.wins}-${s.losses??0}` : null), 'W-L', false],
  ['Strikeouts', s.so, 'SO', false], ['Saves', s.saves, 'SV', false], ['Holds', s.holds, 'H', false],
  ['WHIP', s.whip, 'WHIP', false], ['Innings', s.ip, 'IP', false], ['Games', s.games, 'G', false], ['Win Pct', s.winpct, 'PCT', false],
];
const cards = (isBat ? batCards : pitCards).filter(c => c[1] != null && c[1] !== '');

// TODO: Replace YOURTAG-20 with your Amazon.com Associates tag after registering at affiliate-program.amazon.com
const links = [
  { label: 'Moneyball: The Art of Winning an Unfair Game', url: 'https://www.amazon.com/dp/0393324818?tag=YOURTAG-20', pr: true, description: 'The story that brought sabermetrics to the mainstream. The perfect on-ramp for any fan curious about why data is reshaping baseball.', icon: '💰', bgColor: '#1b5e20', imgUrl: 'https://covers.openlibrary.org/b/isbn/0393324818-M.jpg' },
  { label: 'The Book: Playing the Percentages in Baseball', url: 'https://www.amazon.com/dp/1597971294?tag=YOURTAG-20', pr: true, description: 'The sabermetrics reference that pros actually cite—matchups, platoons, clutch myths, and run/win expectancy, backed by the data.', icon: '📊', bgColor: '#1a3a5c', imgUrl: 'https://covers.openlibrary.org/b/isbn/1597971294-M.jpg' },
  { label: 'Analyzing Baseball Data with R (3rd Ed.)', url: 'https://www.amazon.com/dp/1032668091?tag=YOURTAG-20', pr: true, description: 'Hands-on sabermetrics in R: run expectancy, catcher framing, launch angle and exit velocity. For readers who want to crunch the numbers themselves.', icon: '📈', bgColor: '#2d6a4f', imgUrl: 'https://covers.openlibrary.org/b/isbn/1032668091-M.jpg' },
  { label: 'Pocket Radar Ball Coach (Radar Gun)', url: 'https://www.amazon.com/dp/B00ISCXPJA?tag=YOURTAG-20', pr: true, description: 'Pro-level speed readings (±1 mph) in your pocket—used by MLB teams. Capture your own pitch and exit velocities.', icon: '📡', bgColor: '#0f2540' },
];

const title = `${p.nameRomaji} (${p.name}) — ${NPB_SEASON} Stats | ${p.teamName} | Baseballab`;
const desc  = `${p.nameRomaji} (${p.teamName}, NPB ${leagueEn}) ${NPB_SEASON} season stats & profile. ${snip} Full data on Baseballab.`;
---
<Layout title={title} description={desc} ogUrl={`https://baseballab.com/en/npb/players/${p.slug}/`}>
  <style slot="head">
    .ph { background:var(--navy-dark); color:#fff; padding:2.75rem 0 2rem; }
    .ph .container { display:flex; flex-direction:column; gap:.5rem; }
    .breadcrumb { font-size:.82rem; color:rgba(255,255,255,.7); } .breadcrumb a { color:rgba(255,255,255,.7); }
    .ph-team { font-size:.9rem; opacity:.8; font-weight:600; }
    .ph h1 { font-size:clamp(1.8rem,4vw,2.7rem); font-weight:800; margin:0; }
    .ph-sub { font-size:.9rem; opacity:.8; }
    .pb { padding:2rem 0 4rem; }
    .stats-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(130px,1fr)); gap:.85rem; margin:1.5rem 0 2.5rem; }
    .sc { background:#fff; border:1px solid var(--gray-200); border-radius:10px; padding:1.1rem .9rem; text-align:center; }
    .sc-label { font-size:.68rem; font-weight:700; color:var(--gray-600); text-transform:uppercase; letter-spacing:.06em; margin:0 0 .35rem; }
    .sc-val { font-size:1.7rem; font-weight:800; color:var(--navy); margin:0; line-height:1; font-variant-numeric:tabular-nums; }
    .sc-val.hi { color:var(--red); }
    .sc-sub { font-size:.72rem; color:var(--gray-400); margin:.25rem 0 0; }
    h2.sec { font-size:1.15rem; font-weight:700; color:var(--navy); margin:0 0 .5rem; border-bottom:2px solid var(--navy); padding-bottom:.3rem; }
    .src-note { font-size:.78rem; color:var(--gray-500); margin:0 0 1rem; }
    @media(max-width:560px){ .stats-grid{grid-template-columns:repeat(2,1fr);} }
  </style>

  <section class="ph">
    <div class="container">
      <nav class="breadcrumb">
        <a href="/en/">Baseballab</a> › <a href="/en/npb/">NPB</a> › <a href={`/en/npb/teams/${p.teamSlug}/`}>{p.teamName}</a> › {p.nameRomaji}
      </nav>
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context":"https://schema.org","@type":"BreadcrumbList",
        "itemListElement":[
          {"@type":"ListItem","position":1,"name":"Baseballab","item":"https://baseballab.com/"},
          {"@type":"ListItem","position":2,"name":"NPB","item":"https://baseballab.com/en/npb/"},
          {"@type":"ListItem","position":3,"name":p.teamName,"item":`https://baseballab.com/en/npb/teams/${p.teamSlug}/`},
          {"@type":"ListItem","position":4,"name":p.nameRomaji}
        ]
      })} />
      <p class="ph-team">{p.teamName} · {leagueEn}</p>
      <h1>{p.nameRomaji}</h1>
      <p class="ph-sub">{p.name} · {isBat ? 'Batter' : 'Pitcher'}</p>
    </div>
  </section>

  <div class="pb">
    <div class="container">
      <h2 class="sec">{NPB_SEASON} Stats</h2>
      <p class="src-note">Source: NPB.jp official stats</p>
      {cards.length > 0 ? (
        <div class="stats-grid">
          {cards.map(([label, val, sub, hi]) => (
            <div class="sc">
              <p class="sc-label">{label}</p>
              <p class={`sc-val${hi ? ' hi' : ''}`}>{val}</p>
              <p class="sc-sub">{sub}</p>
            </div>
          ))}
        </div>
      ) : <p style="color:var(--gray-600);padding:1rem 0;">Stats not available for this player.</p>}

      <AffiliateBlock links={links} heading="Recommended for Baseball Analytics" locale="en" />
    </div>
  </div>
</Layout>
