---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import AffiliateBlock from '../../components/AffiliateBlock.astro';
import { buildAmazonUrl } from '../../lib/affiliate.ts';
import linksData from '../../../data/affiliates/links.json';

export async function getStaticPaths() {
  const glossary = await getCollection('glossary');
  return glossary.map(entry => ({
    params: { term: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const { title, description, abbr, atomicAnswer, relatedTerms, difficulty, category } = entry.data;

const difficultyLabel: Record<string, string> = {
  basic: '基礎',
  intermediate: '中級',
  advanced: '上級',
};
const categoryLabel: Record<string, string> = {
  batting: '打撃',
  pitching: '投球',
  fielding: '守備',
  baserunning: '走塁',
  general: '総合',
};

const ogUrl = `https://baseballab.com/glossary/${entry.slug}/`;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  url: ogUrl,
  publisher: {
    '@type': 'Organization',
    name: 'Baseballab',
    url: 'https://baseballab.com',
  },
  mainEntity: {
    '@type': 'Question',
    name: `${abbr ?? title}とは？`,
    acceptedAnswer: {
      '@type': 'Answer',
      text: atomicAnswer,
    },
  },
};

const affiliateLinks = linksData.links.map((item: any) => ({
  label: item.label,
  url: buildAmazonUrl(item.asin, linksData.amazon_tag),
  pr: item.pr,
  description: item.description,
}));
---

<Layout
  title={`${abbr ?? title}とは | Baseballab 指標解説`}
  description={description}
  ogUrl={ogUrl}
  ogType="article"
  jsonLd={jsonLd}
>
  <div class="glossary-page">
    <Breadcrumb items={[
      { label: 'ホーム', href: '/' },
      { label: '指標解説', href: '/glossary/' },
      { label: abbr ?? title },
    ]} />

    <header class="entry-header">
      <div class="meta-tags">
        <span class="tag category">{categoryLabel[category]}</span>
        <span class="tag difficulty">{difficultyLabel[difficulty]}</span>
      </div>
      <h1>{title}</h1>
    </header>

    <div class="atomic-answer">
      <p class="q">Q. {abbr ?? title}とは？</p>
      <p class="a">{atomicAnswer}</p>
    </div>

    <div class="entry-content">
      <Content />
    </div>

    <AffiliateBlock links={affiliateLinks} heading="野球データ分析おすすめ商品" />

    {relatedTerms && relatedTerms.length > 0 && (
      <aside class="related-terms">
        <h2>関連指標</h2>
        <ul>
          {relatedTerms.map(slug => (
            <li><a href={`/glossary/${slug}/`}>{slug.toUpperCase()}</a></li>
          ))}
        </ul>
      </aside>
    )}
  </div>
</Layout>

<style>
  .glossary-page {
    max-width: 760px;
    margin: 0 auto;
    padding: 1.5rem 1rem;
  }
  .entry-header { margin-bottom: 1.5rem; }
  .meta-tags { display: flex; gap: 0.5rem; margin-bottom: 0.75rem; }
  .tag {
    font-size: 0.75rem;
    padding: 0.2rem 0.6rem;
    border-radius: 3px;
    font-weight: 600;
  }
  .tag.category { background: var(--navy, #1a2744); color: #fff; }
  .tag.difficulty { background: var(--gray-1, #eee); color: #333; }
  h1 { font-size: 1.6rem; line-height: 1.3; margin: 0; }
  .atomic-answer {
    background: #e8ecf4;
    border-left: 4px solid var(--navy, #1a2744);
    padding: 1rem 1.25rem;
    margin: 1.5rem 0;
    border-radius: 0 6px 6px 0;
  }
  .atomic-answer .q { font-weight: bold; margin-bottom: 0.5rem; }
  .atomic-answer .a { margin: 0; line-height: 1.7; }
  .entry-content { line-height: 1.8; }
  .entry-content :global(h2) { margin-top: 2rem; font-size: 1.2rem; border-bottom: 2px solid var(--navy, #1a2744); padding-bottom: 0.3rem; }
  .entry-content :global(h3) { margin-top: 1.5rem; font-size: 1.05rem; }
  .entry-content :global(table) { width: 100%; border-collapse: collapse; margin: 1rem 0; font-size: 0.9rem; }
  .entry-content :global(th) { background: var(--navy, #1a2744); color: #fff; padding: 0.5rem 0.75rem; text-align: left; }
  .entry-content :global(td) { padding: 0.45rem 0.75rem; border-bottom: 1px solid #ddd; }
  .entry-content :global(tr:nth-child(even) td) { background: #f5f7fa; }
  .related-terms { margin-top: 3rem; padding-top: 1.5rem; border-top: 1px solid #ddd; }
  .related-terms h2 { font-size: 1rem; margin-bottom: 0.75rem; }
  .related-terms ul { list-style: none; padding: 0; display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .related-terms a {
    display: inline-block;
    padding: 0.3rem 0.75rem;
    border: 1px solid var(--navy, #1a2744);
    border-radius: 3px;
    font-size: 0.85rem;
    color: var(--navy, #1a2744);
    text-decoration: none;
  }
  .related-terms a:hover { background: var(--navy, #1a2744); color: #fff; }
</style>
