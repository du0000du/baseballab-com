---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import AffiliateBlock from '../../components/AffiliateBlock.astro';
import linksData from '../../../data/affiliates/links.json';
import { loadLeaders, NPB_SEASON } from '../../lib/npb';

export async function getStaticPaths() {
  const glossary = await getCollection('glossary');
  return glossary.map(entry => ({
    params: { term: entry.slug },
    props: { entry },
  }));
}

const allTerms = await getCollection('glossary');
const termMap = Object.fromEntries(allTerms.map(t => [t.slug, t.data]));

const { entry } = Astro.props;
const { Content } = await entry.render();
const { title, description, abbr, atomicAnswer, relatedTerms, difficulty, category, publishedAt } = entry.data;

const difficultyLabel: Record<string, string> = {
  basic: '基礎',
  intermediate: '中級',
  advanced: '上級',
};
const categoryLabel: Record<string, string> = {
  batting: '打撃',
  pitching: '投球',
  fielding: '守備',
  baserunning: '走塁',
  general: '総合',
};

const ogUrl = `https://baseballab.com/glossary/${entry.slug}/`;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  url: ogUrl,
  datePublished: publishedAt,
  dateModified: publishedAt,
  publisher: {
    '@type': 'Organization',
    name: 'Baseballab',
    url: 'https://baseballab.com',
  },
  mainEntity: {
    '@type': 'Question',
    name: `${abbr ?? title}とは？`,
    acceptedAnswer: {
      '@type': 'Answer',
      text: atomicAnswer,
    },
  },
};

const affHeadings: Record<string, string> = {
  batting:     `${abbr ?? title}を深掘りする — 打撃分析の参考書`,
  pitching:    `${abbr ?? title}を深掘りする — 投球分析の参考書`,
  fielding:    `${abbr ?? title}を深掘りする — 守備分析の参考書`,
  baserunning: `${abbr ?? title}を深掘りする — セイバーメトリクス参考書`,
  general:     `${abbr ?? title}を深掘りする — セイバーメトリクス参考書`,
};
const affHeading = affHeadings[category] ?? '野球データ分析おすすめ商品';

const affiliateLinks = linksData.links.map((item: any) => ({
  label: item.label,
  url: item.url,
  pr: item.pr,
  description: item.description,
  icon: item.icon,
  imgUrl: item.imgUrl,
  bgColor: item.bgColor,
}));

// glossary slug → leaders data key
const STAT_TO_LEADER: Record<string, {group: 'batting'|'pitching', key: string}> = {
  'avg':       {group: 'batting',  key: 'avg'},
  'ops':       {group: 'batting',  key: 'ops'},
  'rbi':       {group: 'batting',  key: 'rbi'},
  'hr':        {group: 'batting',  key: 'hr'},
  'era':       {group: 'pitching', key: 'era'},
  'whip':      {group: 'pitching', key: 'whip'},
  'sv':        {group: 'pitching', key: 'saves'},
  'hld':       {group: 'pitching', key: 'holds'},
  'strikeout': {group: 'pitching', key: 'so'},
  'k9':        {group: 'pitching', key: 'so'},
};
const leaderDef = STAT_TO_LEADER[entry.slug];
const leadersData = leaderDef ? loadLeaders(NPB_SEASON) : null;
const MEDALS = ['🥇', '🥈', '🥉'];
const npbLeaders: any[] = leaderDef && leadersData
  ? [
      ...((leadersData?.central?.[leaderDef.group]?.[leaderDef.key] ?? []).slice(0, 3).map((r: any) => ({...r, league: 'セ'}))),
      ...((leadersData?.pacific?.[leaderDef.group]?.[leaderDef.key] ?? []).slice(0, 3).map((r: any) => ({...r, league: 'パ'}))),
    ]
  : [];
---

<Layout
  title={`${abbr ?? title}とは | Baseballab 指標解説`}
  description={description}
  ogUrl={ogUrl}
  ogType="article"
  jsonLd={jsonLd}
>
  <div class="glossary-page">
    <Breadcrumb items={[
      { label: 'ホーム', href: '/' },
      { label: '指標解説', href: '/glossary/' },
      { label: abbr ?? title },
    ]} />

    <header class="entry-header">
      <div class="meta-tags">
        <span class="tag category">{categoryLabel[category]}</span>
        <span class="tag difficulty">{difficultyLabel[difficulty]}</span>
      </div>
      <h1>{title}</h1>
    </header>

    <div class="atomic-answer">
      <p class="q">Q. {abbr ?? title}とは？</p>
      <p class="a">{atomicAnswer}</p>
    </div>

    <div class="entry-content">
      <Content />
    </div>

    {npbLeaders.length > 0 && (
      <aside class="npb-leaders-block">
        <p class="nlb-heading">📊 NPB {NPB_SEASON} {abbr ?? title} — 現在の首位選手</p>
        <div class="nlb-cols">
          {(['セ', 'パ'] as const).map(lg => {
            const rows = npbLeaders.filter(r => r.league === lg);
            if (!rows.length) return null;
            return (
              <div class="nlb-col">
                <p class="nlb-lg">{lg === 'セ' ? 'セントラル・リーグ' : 'パシフィック・リーグ'}</p>
                <ol class="nlb-list">
                  {rows.map((r: any, i: number) => (
                    <li>
                      <span class="nlb-medal">{MEDALS[i]}</span>
                      <a href={`/npb/players/${r.slug}/`} class="nlb-player">{r.player}</a>
                      <span class="nlb-team">{r.team}</span>
                      <span class="nlb-val">{r.value}</span>
                    </li>
                  ))}
                </ol>
              </div>
            );
          })}
        </div>
        <a href="/npb/leaders/" class="nlb-more">全部門ランキングを見る →</a>
      </aside>
    )}

    <AffiliateBlock links={affiliateLinks} heading={affHeading} />

    <aside class="see-also">
      <p class="see-also-heading">この指標の成績をランキングで見る</p>
      <ul class="see-also-links">
        <li><a href="/npb/leaders/">NPB 打撃・投球リーダーボード</a></li>
        {category === 'batting' || category === 'general' ? (
          <li><a href="/npb/standings/">NPB 順位表</a></li>
        ) : null}
        <li><a href="/npb/">NPB トップ</a></li>
        <li><a href="/players/">MLB 選手一覧</a></li>
      </ul>
    </aside>

    {relatedTerms && relatedTerms.length > 0 && (
      <aside class="related-terms">
        <h2>関連指標</h2>
        <ul>
          {relatedTerms.map(slug => {
            const t = termMap[slug];
            const label = t?.abbr ?? t?.title ?? slug.toUpperCase();
            return <li><a href={`/glossary/${slug}/`}>{label}</a></li>;
          })}
        </ul>
      </aside>
    )}
  </div>
</Layout>

<style>
  .glossary-page {
    max-width: 760px;
    margin: 0 auto;
    padding: 1.5rem 1rem;
  }
  .entry-header { margin-bottom: 1.5rem; }
  .meta-tags { display: flex; gap: 0.5rem; margin-bottom: 0.75rem; }
  .tag {
    font-size: 0.75rem;
    padding: 0.2rem 0.6rem;
    border-radius: 3px;
    font-weight: 600;
  }
  .tag.category { background: var(--navy, #1a2744); color: #fff; }
  .tag.difficulty { background: var(--gray-1, #eee); color: #333; }
  h1 { font-size: 1.6rem; line-height: 1.3; margin: 0; }
  .atomic-answer {
    background: #e8ecf4;
    border-left: 4px solid var(--navy, #1a2744);
    padding: 1rem 1.25rem;
    margin: 1.5rem 0;
    border-radius: 0 6px 6px 0;
  }
  .atomic-answer .q { font-weight: bold; margin-bottom: 0.5rem; }
  .atomic-answer .a { margin: 0; line-height: 1.7; }
  .entry-content { line-height: 1.8; }
  .entry-content :global(h2) { margin-top: 2rem; font-size: 1.2rem; border-bottom: 2px solid var(--navy, #1a2744); padding-bottom: 0.3rem; }
  .entry-content :global(h3) { margin-top: 1.5rem; font-size: 1.05rem; }
  .entry-content :global(table) { width: 100%; border-collapse: collapse; margin: 1rem 0; font-size: 0.9rem; }
  .entry-content :global(th) { background: var(--navy, #1a2744); color: #fff; padding: 0.5rem 0.75rem; text-align: left; }
  .entry-content :global(td) { padding: 0.45rem 0.75rem; border-bottom: 1px solid #ddd; }
  .entry-content :global(tr:nth-child(even) td) { background: #f5f7fa; }
  .npb-leaders-block { margin-top: 2.5rem; padding: 1rem 1.25rem; background: #f0f4f8; border-radius: 8px; border-left: 4px solid var(--navy, #1a2744); }
  .nlb-heading { font-size: .78rem; font-weight: 700; color: var(--navy, #1a2744); text-transform: uppercase; letter-spacing: .05em; margin: 0 0 .85rem; }
  .nlb-cols { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  .nlb-lg { font-size: .7rem; font-weight: 700; color: var(--gray-500, #666); margin: 0 0 .4rem; }
  .nlb-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: .35rem; }
  .nlb-list li { display: flex; align-items: center; gap: .4rem; font-size: .83rem; }
  .nlb-medal { font-size: .9rem; flex-shrink: 0; }
  .nlb-player { font-weight: 700; color: var(--navy, #1a2744); text-decoration: none; }
  .nlb-player:hover { text-decoration: underline; color: var(--accent, #c0392b); }
  .nlb-team { font-size: .7rem; color: var(--gray-500, #666); }
  .nlb-val { font-weight: 800; color: var(--navy, #1a2744); margin-left: auto; font-variant-numeric: tabular-nums; }
  .nlb-more { display: inline-block; margin-top: .75rem; font-size: .78rem; font-weight: 700; color: var(--navy, #1a2744); text-decoration: none; }
  .nlb-more:hover { text-decoration: underline; }
  @media (max-width: 480px) { .nlb-cols { grid-template-columns: 1fr; } }
  .see-also { margin-top: 2.5rem; padding: 1rem 1.25rem; background: #f0f4f8; border-radius: 8px; }
  .see-also-heading { font-size: .78rem; font-weight: 700; color: var(--gray-500, #6b6760); text-transform: uppercase; letter-spacing: .06em; margin: 0 0 .6rem; }
  .see-also-links { display: flex; flex-wrap: wrap; gap: .4rem; list-style: none; padding: 0; margin: 0; }
  .see-also-links a { display: inline-block; background: #fff; border: 1px solid var(--border, #ddd); border-radius: 20px; padding: .2rem .75rem; font-size: .82rem; font-weight: 600; color: var(--navy, #1a2744); text-decoration: none; }
  .see-also-links a:hover { border-color: var(--navy, #1a2744); background: var(--navy, #1a2744); color: #fff; }
  .related-terms { margin-top: 3rem; padding-top: 1.5rem; border-top: 1px solid #ddd; }
  .related-terms h2 { font-size: 1rem; margin-bottom: 0.75rem; }
  .related-terms ul { list-style: none; padding: 0; display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .related-terms a {
    display: inline-block;
    padding: 0.3rem 0.75rem;
    border: 1px solid var(--navy, #1a2744);
    border-radius: 3px;
    font-size: 0.85rem;
    color: var(--navy, #1a2744);
    text-decoration: none;
  }
  .related-terms a:hover { background: var(--navy, #1a2744); color: #fff; }
</style>
