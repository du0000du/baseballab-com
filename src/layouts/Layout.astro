---
// Baseballab — 共通レイアウト
// TASK-001: Layout.astro 共通レイアウト作成
// TASK-038: デザイン高級感向上（フォント・カラーパレット改善）


interface Props {
  title: string;
  description: string;
  ogUrl?: string;
  ogType?: string;
  ogImage?: string;
  jsonLd?: Record<string, unknown>;
}


const {
  title,
  description,
  ogUrl = 'https://baseballab.com',
  ogType = 'website',
  ogImage = 'https://baseballab.com/og-default.png',
  jsonLd,
} = Astro.props;
---


<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={ogUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="ja_JP" />
    <meta property="og:site_name" content="Baseballab" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <title>{title}</title>
    {jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}
    <!-- Google Search Console -->
    <meta name="google-site-verification" content="vWPBl9eQ48HmYqfIbqNQXHE8N6JbFVidI1Uu8N6rByI" />
    <!-- Google Fonts: Inter + Noto Sans JP -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Noto+Sans+JP:wght@400;500;700&display=swap" rel="stylesheet" />
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-JZSRYVP3N9"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-JZSRYVP3N9');
    </script>
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      :root {
        /* Color palette — refined for premium feel */
        --navy:        #152a42;
        --navy-dark:   #0c1e33;
        --navy-light:  #1e3d5c;
        --accent:      #9b2335;
        --accent-hover:#7d1c2a;
        --accent-light: rgba(155,35,53,0.08);
        --red:         #9b2335;
        --red-hover:   #7d1c2a;
        --white:       #ffffff;
        --bg:          #f8f7f4;
        --bg-card:     #ffffff;
        --border:      #e4e2dc;
        --border-light:#eeece6;
        --gray-100:    #f2f0ec;
        --gray-200:    #e4e2dc;
        --gray-400:    #a8a49a;
        --gray-500:    #8a8680;
        --gray-600:    #6b6760;
        --gray-800:    #3a3832;
        --text:        #1a1a2a;
        --text-muted:  #6b6760;
        /* Typography */
        --font-en:  'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
        --font-ja:  'Noto Sans JP', 'Hiragino Kaku Gothic ProN', 'Hiragino Sans', Meiryo, sans-serif;
        --font:     var(--font-en), var(--font-ja);
        /* Shadows */
        --shadow-sm: 0 1px 3px rgba(15,25,40,0.08), 0 1px 2px rgba(15,25,40,0.04);
        --shadow-md: 0 4px 12px rgba(15,25,40,0.10), 0 2px 4px rgba(15,25,40,0.06);
        --shadow-lg: 0 8px 28px rgba(15,25,40,0.13), 0 4px 8px rgba(15,25,40,0.07);
        /* Transitions */
        --transition: 0.18s ease;
      }
      html { scroll-behavior: smooth; -webkit-text-size-adjust: 100%; }
      body {
        font-family: var(--font);
        font-size: 16px;
        line-height: 1.78;
        color: var(--text);
        background: var(--bg);
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }
      img { max-width: 100%; height: auto; display: block; }
      a { color: inherit; text-decoration: none; }
      ul { list-style: none; }
      /* Numeric characters use Inter for clean tabular alignment */
      .num { font-family: var(--font-en); font-variant-numeric: tabular-nums; }

      /* Layout */
      .container { max-width: 1100px; margin: 0 auto; padding: 0 1.5rem; }
      @media (max-width: 480px) { .container { padding: 0 1.1rem; } }

      /* ── Header ── */
      .site-header {
        background: var(--navy-dark);
        color: var(--white);
        position: sticky;
        top: 0;
        z-index: 100;
        border-bottom: 1px solid rgba(255,255,255,0.07);
        box-shadow: 0 2px 12px rgba(0,0,0,0.28);
      }
      .header-inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0.8rem 1.5rem;
        max-width: 1100px;
        margin: 0 auto;
      }
      .site-logo {
        font-family: var(--font-en);
        font-size: 1.35rem;
        font-weight: 800;
        letter-spacing: -0.045em;
        color: var(--white);
        display: flex;
        align-items: center;
      }
      .site-logo span { color: var(--accent); }
      .site-logo:hover { opacity: 0.9; }
      .site-nav {
        display: flex;
        gap: 1.75rem;
        font-family: var(--font-en);
        font-size: 0.875rem;
        font-weight: 500;
        letter-spacing: 0.01em;
      }
      .site-nav a {
        color: rgba(255,255,255,0.75);
        transition: color var(--transition);
        padding-bottom: 2px;
        border-bottom: 1px solid transparent;
      }
      .site-nav a:hover {
        color: var(--white);
        border-bottom-color: rgba(255,255,255,0.4);
      }
      @media (max-width: 768px) { .site-nav { display: none; } }

      /* ── Footer ── */
      .site-footer {
        background: var(--navy-dark);
        color: rgba(255,255,255,0.55);
        padding: 2.75rem 1.5rem 2rem;
        text-align: center;
        font-size: 0.82rem;
        border-top: 1px solid rgba(255,255,255,0.06);
      }
      .footer-nav {
        display: flex;
        justify-content: center;
        gap: 1.75rem;
        margin-bottom: 1.25rem;
        flex-wrap: wrap;
        font-size: 0.82rem;
      }
      .footer-nav a {
        color: rgba(255,255,255,0.55);
        transition: color var(--transition);
      }
      .footer-nav a:hover { color: rgba(255,255,255,0.9); }
      .footer-copy { font-size: 0.75rem; opacity: 0.45; letter-spacing: 0.02em; }
    </style>
    <slot name="head" />
  </head>
  <body>
    <header class="site-header">
      <div class="header-inner">
        <a href="/" class="site-logo">Basebal<span>lab</span></a>
        <nav class="site-nav" aria-label="メインナビゲーション">
          <a href="/mlb/">MLB</a>
          <a href="/npb/">NPB</a>
          <a href="/glossary/">指標解説</a>
          <a href="/gear/">機材</a>
          <a href="/streaming/">配信</a>
        </nav>
      </div>
    </header>
    <slot />
    <footer class="site-footer">
      <nav class="footer-nav" aria-label="フッターナビゲーション">
        <a href="/privacy/">プライバシーポリシー</a>
        <a href="/disclaimer/">免責事項</a>
        <a href="/about/">運営者情報</a>
        <a href="/contact/">お問い合わせ</a>
        <a href="/disclosure/">広告について</a>
      </nav>
      <p class="footer-copy">&copy; 2026 Baseballab. All rights reserved.</p>
    </footer>
  </body>
</html>
