---
// Baseballab — 共通レイアウト
// TASK-001: Layout.astro 共通レイアウト作成

interface Props {
  title: string;
  description: string;
  ogUrl?: string;
  ogType?: string;
}

const {
  title,
  description,
  ogUrl = 'https://baseballab.com',
  ogType = 'website',
} = Astro.props;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={ogUrl} />
    <title>{title}</title>
    <!-- Google Search Console -->
    <meta name="google-site-verification" content="vWPBl9eQ48HmYqfIbqNQXHE8N6JbFVidI1Uu8N6rByI" />
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-JZSRYVP3N9"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-JZSRYVP3N9');
    </script>
    <style>
      /* ===== RESET & BASE ===== */
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      :root {
        --navy: #1a3a5c;
        --navy-dark: #0f2540;
        --navy-light: #274d75;
        --red: #c0392b;
        --red-hover: #a93226;
        --white: #ffffff;
        --gray-100: #f8f9fa;
        --gray-200: #e9ecef;
        --gray-400: #adb5bd;
        --gray-600: #6c757d;
        --gray-800: #343a40;
        --text: #212529;
        --font: 'Helvetica Neue', Arial, 'Hiragino Kaku Gothic ProN', 'Hiragino Sans', Meiryo, sans-serif;
      }

      html { scroll-behavior: smooth; }

      body {
        font-family: var(--font);
        font-size: 16px;
        line-height: 1.7;
        color: var(--text);
        background: var(--white);
      }

      img { max-width: 100%; height: auto; display: block; }
      a { color: inherit; text-decoration: none; }
      ul { list-style: none; }

      .container {
        max-width: 1100px;
        margin: 0 auto;
        padding: 0 1.25rem;
      }

      /* ===== HEADER / NAV ===== */
      .site-header {
        background: var(--navy);
        color: var(--white);
        position: sticky;
        top: 0;
        z-index: 100;
        box-shadow: 0 2px 8px rgba(0,0,0,0.25);
      }

      .header-inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0.75rem 1.25rem;
        max-width: 1100px;
        margin: 0 auto;
      }

      .site-logo {
        font-size: 1.4rem;
        font-weight: 800;
        letter-spacing: -0.03em;
        display: flex;
        align-items: center;
        gap: 0.4rem;
      }
      .site-logo .logo-accent { color: var(--red); }

      .site-nav {
        display: flex;
        gap: 1.5rem;
        font-size: 0.9rem;
        font-weight: 500;
      }
      .site-nav a { opacity: 0.85; transition: opacity 0.15s; }
      .site-nav a:hover { opacity: 1; }

      /* ===== FOOTER ===== */
      .site-footer {
        background: var(--navy-dark);
        color: rgba(255,255,255,0.65);
        padding: 2.5rem 1.25rem;
        text-align: center;
        font-size: 0.85rem;
      }

      .footer-nav {
        display: flex;
        justify-content: center;
        gap: 2rem;
        margin-bottom: 1.25rem;
        flex-wrap: wrap;
      }
      .footer-nav a { transition: color 0.15s; }
      .footer-nav a:hover { color: var(--white); }

      .footer-copy {
        font-size: 0.8rem;
        opacity: 0.55;
      }

      /* ===== RESPONSIVE ===== */
      @media (max-width: 768px) {
        .site-nav { display: none; }
      }
    </style>
    <!-- ページ固有のスタイル・メタをここに差し込む -->
    <slot name="head" />
  </head>
  <body>

    <!-- ===== HEADER ===== -->
    <header class="site-header">
      <div class="header-inner">
        <a href="/" class="site-logo"><span class="logo-icon">⚾</span><span class="logo-text">Basebal<span class="logo-accent">lab</span></span></a>
        <nav class="site-nav" aria-label="メインナビゲーション">
          <a href="/mlb/">MLB</a>
          <a href="/npb/">NPB</a>
          <a href="/glossary/">指標解説</a>
          <a href="/gear/">機材</a>
          <a href="/streaming/">配信</a>
        </nav>
      </div>
    </header>

    <!-- ===== ページコンテンツ ===== -->
    <slot />

    <!-- ===== FOOTER ===== -->
    <footer class="site-footer">
      <nav class="footer-nav" aria-label="フッターナビゲーション">
        <a href="/privacy/">プライバシーポリシー</a>
        <a href="/disclaimer/">免責事項</a>
        <a href="/about/">運営者情報</a>
        <a href="/contact/">お問い合わせ</a>
      </nav>
      <p class="footer-copy">&copy; 2024 Baseballab. All rights reserved.</p>
    </footer>

  </body>
</html>
