---
// Baseballab — 共通レイアウト
// TASK-001: Layout.astro 共通レイアウト作成

interface Props {
  title: string;
  description: string;
  ogUrl?: string;
  ogType?: string;
  jsonLd?: Record<string, unknown>;
}

const {
  title,
  description,
  ogUrl = 'https://baseballab.com',
  ogType = 'website',
  jsonLd,
} = Astro.props;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={ogUrl} />
    <title>{title}</title>
    <!-- Google Search Console -->
    <meta name="google-site-verification" content="vWPBl9eQ48HmYqfIbqNQXHE8N6JbFVidI1Uu8N6rByI" />
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-JZSRYVP3N9"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-JZSRYVP3N9');
    </script>
    <style>
      /* ===== RESET & BASE ===== */
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      :root {
        --navy: #1a3a5c;
        --navy-dark: #0f2540;
        --navy-light: #274d75;
        --red: #c0392b;
        --red-hover: #a93226;
        --white: #ffffff;
        --gray-100: #f8f9fa;
        --gray-200: #e9ecef;
        --gray-400: #adb5bd;
        --gray-600: #6c757d;
        --gray-800: #343a40;
        --text: #212529;
        --font: 'Helvetica Neue', Arial, 'Hiragino Kaku Gothic ProN', 'Hiragino Sans', Meiryo, sans-serif;
      }

      html { scroll-behavior: smooth; }

      body {
        font-family: var(--font);
        font-size: 16px;
        line-height: 1.7;
        color: var(--text);
        background: var(--white);
      }

      img { max-width: 100%; height: auto; display: block; }
      a { color: inherit; text-decoration: none; }
      ul { list-style: none; }

      .container {
        max-width: 1100px;
        margin: 0 auto;
        padding: 0 1.25rem;
      }

      /* ===== HEADER / NAV ===== */
      .site-header {
        background: var(--navy);
        color: var(--white);
        position: sticky;
        top: 0;
        z-index: 100;
        box-shadow: 0 2px 8px rgba(0,0,0,0.25);
      }

      .header-inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0.75rem 1.25rem;
        max-width: 1100px;
        margin: 0 auto;
      }

      .site-logo {
        font-size: 1.4rem;
        font-weight: 800;
        letter-spacing: -0.03em;
        display: flex;
        align-items: center;
        gap: 0.4rem;
      }
      .site-logo .logo-accent { color: var(--red); }

      .site-nav {
        display: flex;
        gap: 1.5rem;
        font-size: 0.9rem;
        font-weight: 500;
      }
      .site-nav a { opacity: 0.85; transition: opacity 0.15s; }
      .site-nav a:hover { opacity: 1; }

      /* ===== FOOTER ===== */
      .site-footer {
        background: var(--navy-dark);
        color: rgba(255,255,255,0.65);
        padding: 2.5rem 1.25rem;
        text-align: center;
        font-size: 0.85rem;
      }

      .footer-links {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
        gap: 1.5rem 2rem;
        max-width: 900px;
        margin: 0 auto 2rem;
        text-align: left;
      }
      .footer-col-title {
        font-size: .72rem;
        font-weight: 700;
        letter-spacing: .1em;
        text-transform: uppercase;
        color: rgba(255,255,255,.5);
        margin: 0 0 .6rem;
      }
      .footer-col-nav { display: flex; flex-direction: column; gap: .35rem; }
      .footer-col-nav a { font-size: .8rem; color: rgba(255,255,255,.65); transition: color .15s; }
      .footer-col-nav a:hover { color: var(--white); }

      .footer-nav {
        display: flex;
        justify-content: center;
        gap: 2rem;
        margin-bottom: 1rem;
        flex-wrap: wrap;
        border-top: 1px solid rgba(255,255,255,.1);
        padding-top: 1.25rem;
        margin-top: .5rem;
      }
      .footer-nav a { transition: color 0.15s; font-size: .8rem; }
      .footer-nav a:hover { color: var(--white); }

      .footer-copy {
        font-size: 0.8rem;
        opacity: 0.55;
      }

      @media (max-width: 600px) {
        .footer-links { grid-template-columns: repeat(2, 1fr); }
      }

      /* ===== RESPONSIVE ===== */
      .hamburger {
        display: none;
        flex-direction: column;
        gap: 5px;
        background: none;
        border: none;
        cursor: pointer;
        padding: 4px;
      }
      .hamburger span {
        display: block;
        width: 22px;
        height: 2px;
        background: var(--white);
        border-radius: 2px;
        transition: transform 0.2s, opacity 0.2s;
      }
      .mobile-nav {
        display: none;
        flex-direction: column;
        background: var(--navy-dark);
        padding: 0.5rem 1.25rem 1rem;
      }
      .mobile-nav a {
        color: rgba(255,255,255,0.85);
        font-size: 1rem;
        font-weight: 600;
        padding: 0.7rem 0;
        border-bottom: 1px solid rgba(255,255,255,0.08);
      }
      .mobile-nav a:last-child { border-bottom: none; }
      .mobile-nav.open { display: flex; }

      @media (max-width: 768px) {
        .site-nav { display: none; }
        .hamburger { display: flex; }
      }
    </style>
    {jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}
    <!-- ページ固有のスタイル・メタをここに差し込む -->
    <slot name="head" />
  </head>
  <body>

    <!-- ===== HEADER ===== -->
    <header class="site-header">
      <div class="header-inner">
        <a href="/" class="site-logo"><span class="logo-icon">⚾</span><span class="logo-text">Basebal<span class="logo-accent">lab</span></span></a>
        <nav class="site-nav" aria-label="メインナビゲーション">
          <a href="/mlb/">MLB</a>
          <a href="/npb/">NPB</a>
          <a href="/glossary/">指標解説</a>
          <a href="/gear/">機材</a>
          <a href="/streaming/">配信</a>
        </nav>
        <button class="hamburger" aria-label="メニューを開く" aria-expanded="false" aria-controls="mobile-nav">
          <span></span><span></span><span></span>
        </button>
      </div>
    </header>
    <nav id="mobile-nav" class="mobile-nav" aria-label="モバイルナビゲーション">
      <a href="/mlb/">MLB</a>
      <a href="/npb/">NPB</a>
      <a href="/glossary/">指標解説</a>
      <a href="/gear/">機材</a>
      <a href="/streaming/">配信</a>
    </nav>
    <script is:inline>
      (function(){
        var btn = document.querySelector('.hamburger');
        var nav = document.getElementById('mobile-nav');
        if (!btn || !nav) return;
        btn.addEventListener('click', function(){
          var open = nav.classList.toggle('open');
          btn.setAttribute('aria-expanded', open ? 'true' : 'false');
        });
      })();
    </script>

    <!-- ===== ページコンテンツ ===== -->
    <slot />

    <!-- ===== FOOTER ===== -->
    <footer class="site-footer">
      <div class="footer-links">
        <div class="footer-col">
          <p class="footer-col-title">指標解説</p>
          <nav class="footer-col-nav">
            <a href="/glossary/sabermetrics/">セイバーメトリクスとは</a>
            <a href="/glossary/war/">WAR</a>
            <a href="/glossary/ops/">OPS</a>
            <a href="/glossary/fip/">FIP</a>
            <a href="/glossary/woba/">wOBA</a>
            <a href="/glossary/">すべての指標 →</a>
          </nav>
        </div>
        <div class="footer-col">
          <p class="footer-col-title">打撃指標</p>
          <nav class="footer-col-nav">
            <a href="/glossary/avg/">打率（AVG）</a>
            <a href="/glossary/obp/">出塁率（OBP）</a>
            <a href="/glossary/slg/">長打率（SLG）</a>
            <a href="/glossary/wrc-plus/">wRC+</a>
            <a href="/glossary/babip/">BABIP</a>
          </nav>
        </div>
        <div class="footer-col">
          <p class="footer-col-title">投球指標</p>
          <nav class="footer-col-nav">
            <a href="/glossary/era/">防御率（ERA）</a>
            <a href="/glossary/whip/">WHIP</a>
            <a href="/glossary/k9/">K/9</a>
            <a href="/glossary/xfip/">xFIP</a>
            <a href="/glossary/siera/">SIERA</a>
          </nav>
        </div>
        <div class="footer-col">
          <p class="footer-col-title">データ</p>
          <nav class="footer-col-nav">
            <a href="/mlb/">MLB データ</a>
            <a href="/mlb/leaders/">MLB ランキング</a>
            <a href="/npb/">NPB データ</a>
            <a href="/players/">MLB 選手一覧</a>
            <a href="/teams/">チーム一覧</a>
          </nav>
        </div>
      </div>
      <nav class="footer-nav" aria-label="フッターナビゲーション">
        <a href="/privacy/">プライバシーポリシー</a>
        <a href="/disclaimer/">免責事項</a>
        <a href="/disclosure/">広告について</a>
      </nav>
      <p class="footer-copy">&copy; 2026 Baseballab. All rights reserved.</p>
    </footer>

  </body>
</html>
