---
// Baseballab — 共通レイアウト
// TASK-001: Layout.astro 共通レイアウト作成

interface Props {
  title: string;
  description: string;
  ogUrl?: string;
  ogType?: string;
  jsonLd?: Record<string, unknown>;
}

const {
  title,
  description,
  ogUrl = 'https://baseballab.com',
  ogType = 'website',
  jsonLd,
} = Astro.props;

const pathname = Astro.url.pathname;
const isEn = pathname.startsWith('/en/') || pathname === '/en';
const lang = isEn ? 'en' : 'ja';
const jaUrl = isEn ? (pathname.replace(/^\/en/, '') || '/') : pathname;
const enUrl = isEn ? pathname : ('/en' + pathname);
const jaAbsolute = `https://baseballab.com${jaUrl}`;
const enAbsolute = `https://baseballab.com${enUrl}`;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={ogUrl} />
    <link rel="canonical" href={ogUrl} />
    <link rel="alternate" hreflang="ja" href={jaAbsolute} />
    <link rel="alternate" hreflang="en" href={enAbsolute} />
    <link rel="alternate" hreflang="x-default" href={jaAbsolute} />
    <title>{title}</title>
    <!-- Google Search Console -->
    <meta name="google-site-verification" content="vWPBl9eQ48HmYqfIbqNQXHE8N6JbFVidI1Uu8N6rByI" />
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-JZSRYVP3N9"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-JZSRYVP3N9');
    </script>
    <style>
      /* ===== RESET & BASE ===== */
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      :root {
        --navy: #1a3a5c;
        --navy-dark: #0f2540;
        --navy-light: #274d75;
        --red: #c0392b;
        --red-hover: #a93226;
        --white: #ffffff;
        --gray-100: #f8f9fa;
        --gray-200: #e9ecef;
        --gray-400: #adb5bd;
        --gray-600: #6c757d;
        --gray-800: #343a40;
        --text: #212529;
        --font: 'Helvetica Neue', Arial, 'Hiragino Kaku Gothic ProN', 'Hiragino Sans', Meiryo, sans-serif;
        --shadow-sm: 0 1px 4px rgba(0,0,0,0.07);
        --shadow-md: 0 4px 12px rgba(0,0,0,0.09);
        --shadow-lg: 0 10px 30px rgba(0,0,0,0.12);
        --border: #e9ecef;
        --bg-card: #ffffff;
        --accent: #c0392b;
        --accent-light: rgba(192,57,43,0.06);
        --transition: 0.15s ease;
      }

      html { scroll-behavior: smooth; }

      body {
        font-family: var(--font);
        font-size: 16px;
        line-height: 1.7;
        color: var(--text);
        background: var(--white);
      }

      img { max-width: 100%; height: auto; display: block; }
      a { color: #2563eb; text-decoration: none; }
      .site-header a, .site-footer a { color: inherit; }
      ul { list-style: none; }
      table { font-variant-numeric: tabular-nums; }
      table th { font-size: .78rem; }
      table tbody tr:hover { background: rgba(0,0,0,.06); }
      .entry-content a { text-decoration: underline; }
      .entry-content table { display: block; overflow-x: auto; }

      .container {
        max-width: 1100px;
        margin: 0 auto;
        padding: 0 1.25rem;
      }

      /* ===== HEADER / NAV ===== */
      .site-header {
        background: var(--navy);
        color: var(--white);
        position: sticky;
        top: 0;
        z-index: 100;
        box-shadow: 0 2px 8px rgba(0,0,0,0.25);
      }

      .header-inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0.75rem 1.25rem;
        max-width: 1100px;
        margin: 0 auto;
      }

      .site-logo {
        font-size: 1.4rem;
        font-weight: 800;
        letter-spacing: -0.03em;
        display: flex;
        align-items: center;
        gap: 0.4rem;
      }
      .site-logo .logo-accent { color: var(--red); }

      .site-nav {
        display: flex;
        gap: 1.5rem;
        font-size: 0.9rem;
        font-weight: 500;
      }
      .site-nav a { opacity: 0.85; transition: opacity 0.15s; }
      .site-nav a:hover { opacity: 1; }

      /* ===== FOOTER ===== */
      .site-footer {
        background: var(--navy-dark);
        color: rgba(255,255,255,0.65);
        padding: 2.5rem 1.25rem;
        text-align: center;
        font-size: 0.85rem;
      }

      .footer-links {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
        gap: 1.5rem 2rem;
        max-width: 900px;
        margin: 0 auto 2rem;
        text-align: left;
      }
      .footer-col-title {
        font-size: .72rem;
        font-weight: 700;
        letter-spacing: .1em;
        text-transform: uppercase;
        color: rgba(255,255,255,.5);
        margin: 0 0 .6rem;
      }
      .footer-col-nav { display: flex; flex-direction: column; gap: .35rem; }
      .footer-col-nav a { font-size: .8rem; color: rgba(255,255,255,.65); transition: color .15s; }
      .footer-col-nav a:hover { color: var(--white); }

      .footer-nav {
        display: flex;
        justify-content: center;
        gap: 2rem;
        margin-bottom: 1rem;
        flex-wrap: wrap;
        border-top: 1px solid rgba(255,255,255,.1);
        padding-top: 1.25rem;
        margin-top: .5rem;
      }
      .footer-nav a { transition: color 0.15s; font-size: .8rem; }
      .footer-nav a:hover { color: var(--white); }

      .footer-copy {
        font-size: 0.8rem;
        opacity: 0.55;
      }

      @media (max-width: 600px) {
        .footer-links { grid-template-columns: repeat(2, 1fr); }
      }

      /* ===== RESPONSIVE ===== */
      .hamburger {
        display: none;
        flex-direction: column;
        gap: 5px;
        background: none;
        border: none;
        cursor: pointer;
        padding: 4px;
      }
      .hamburger span {
        display: block;
        width: 22px;
        height: 2px;
        background: var(--white);
        border-radius: 2px;
        transition: transform 0.2s, opacity 0.2s;
      }
      .mobile-nav {
        display: none;
        flex-direction: column;
        background: var(--navy-dark);
        padding: 0.5rem 1.25rem 1rem;
      }
      .mobile-nav a {
        color: rgba(255,255,255,0.85);
        font-size: 1rem;
        font-weight: 600;
        padding: 0.7rem 0;
        border-bottom: 1px solid rgba(255,255,255,0.08);
      }
      .mobile-nav a:last-child { border-bottom: none; }
      .mobile-nav.open { display: flex; }

      @media (max-width: 768px) {
        .site-nav { display: none; }
        .hamburger { display: flex; }
      }

      /* ===== LANG SWITCHER ===== */
      .lang-switcher {
        display: flex;
        align-items: center;
        border: 1px solid rgba(255,255,255,0.3);
        border-radius: 6px;
        overflow: hidden;
        font-size: 0.78rem;
        font-weight: 700;
        flex-shrink: 0;
        margin-left: 0.75rem;
      }
      .lang-btn {
        padding: 0.28rem 0.6rem;
        color: rgba(255,255,255,0.6);
        text-decoration: none;
        transition: background 0.15s, color 0.15s;
        white-space: nowrap;
      }
      .lang-btn:hover { background: rgba(255,255,255,0.12); color: var(--white); }
      .lang-btn.active { background: rgba(255,255,255,0.18); color: var(--white); }
      .lang-divider { color: rgba(255,255,255,0.2); padding: 0 1px; font-size: 0.65rem; }
      @media (max-width: 768px) { .lang-switcher { margin-left: 0; } }

      /* ===== SPEED BAR ===== */
      .speed-bar {
        background: #0a1d35;
        border-bottom: 1px solid rgba(255,255,255,.08);
        padding: .3rem 0;
      }
      .speed-bar-inner {
        display: flex;
        align-items: center;
        gap: 0;
        max-width: 1100px;
        margin: 0 auto;
        padding: 0 1.25rem;
        flex-wrap: nowrap;
        overflow-x: auto;
      }
      .sb-section { display: flex; align-items: center; gap: 0; flex-shrink: 0; }
      .sb-label {
        font-size: .62rem;
        font-weight: 800;
        letter-spacing: .08em;
        color: #fff;
        padding: .18rem .55rem;
        border-radius: 4px;
        margin-right: .45rem;
        flex-shrink: 0;
        white-space: nowrap;
      }
      .sb-label.npb { background: #9b2335; }
      .sb-label.mlb { background: #003087; }
      .sb-divider {
        width: 1px;
        height: 1.1rem;
        background: rgba(255,255,255,.18);
        margin: 0 .7rem;
        flex-shrink: 0;
      }
      .speed-link {
        display: inline-flex;
        align-items: center;
        gap: .3rem;
        padding: .25rem .65rem;
        font-size: .76rem;
        font-weight: 700;
        color: rgba(255,255,255,.72);
        border-radius: 5px;
        transition: background .12s, color .12s;
        white-space: nowrap;
        text-decoration: none;
      }
      .speed-link:hover { background: rgba(255,255,255,.1); color: #fff; }
      .speed-link .sl-icon { font-size: .88rem; line-height: 1; }
      .speed-sep { color: rgba(255,255,255,.15); margin: 0 .05rem; font-size: .55rem; }
      @media (max-width: 640px) {
        .sb-label { font-size: .58rem; padding: .15rem .42rem; }
        .speed-link { padding: .22rem .45rem; font-size: .7rem; }
        .speed-link .sl-text { display: none; }
        .sb-divider { margin: 0 .45rem; }
      }
    </style>
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Baseballab",
      "url": "https://baseballab.com",
      "logo": "https://baseballab.com/favicon.svg",
      "description": isEn
        ? "Data-driven analysis of MLB & NPB statistics — sabermetrics explained for fans, coaches and analysts."
        : "MLB・NPBのデータをセイバーメトリクスで深掘りする野球統計メディア",
      "sameAs": [],
      "contactPoint": { "@type": "ContactPoint", "email": "info@transdata.tv", "contactType": "customer support" }
    })} />
    {jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}
    <!-- ページ固有のスタイル・メタをここに差し込む -->
    <slot name="head" />
  </head>
  <body>

    <!-- ===== HEADER ===== -->
    <header class="site-header">
      <div class="header-inner">
        <a href={isEn ? '/en/' : '/'} class="site-logo"><span class="logo-icon">⚾</span><span class="logo-text">Basebal<span class="logo-accent">lab</span></span></a>
        <nav class="site-nav" aria-label={isEn ? 'Main navigation' : 'メインナビゲーション'}>
          {isEn ? (
            <>
              <a href="/en/mlb/">MLB</a>
              <a href="/en/npb/">NPB</a>
              <a href="/en/glossary/">Stats Guide</a>
            </>
          ) : (
            <>
              <a href="/mlb/">MLB</a>
              <a href="/npb/">NPB</a>
              <a href="/glossary/">指標解説</a>
              <a href="/gear/">機材</a>
              <a href="/streaming/">配信</a>
              <a href="/search/" aria-label="検索">🔍</a>
            </>
          )}
        </nav>
        <div class="lang-switcher" role="navigation" aria-label="言語切替 / Language">
          <a href={jaUrl} class={`lang-btn${!isEn ? ' active' : ''}`}>日本語</a>
          <span class="lang-divider">|</span>
          <a href={enUrl} class={`lang-btn${isEn ? ' active' : ''}`}>English</a>
        </div>
        <button class="hamburger" aria-label={isEn ? 'Open menu' : 'メニューを開く'} aria-expanded="false" aria-controls="mobile-nav">
          <span></span><span></span><span></span>
        </button>
      </div>
    </header>
    <nav id="mobile-nav" class="mobile-nav" aria-label={isEn ? 'Mobile navigation' : 'モバイルナビゲーション'}>
      {isEn ? (
        <>
          <a href="/en/mlb/">MLB</a>
          <a href="/en/npb/">NPB</a>
          <a href="/en/glossary/">Stats Guide</a>
        </>
      ) : (
        <>
          <a href="/mlb/">MLB</a>
          <a href="/npb/">NPB</a>
          <a href="/glossary/">指標解説</a>
          <a href="/gear/">機材</a>
          <a href="/streaming/">配信</a>
          <a href="/search/">🔍 検索</a>
        </>
      )}
    </nav>
    <script is:inline>
      (function(){
        var btn = document.querySelector('.hamburger');
        var nav = document.getElementById('mobile-nav');
        if (!btn || !nav) return;
        btn.addEventListener('click', function(){
          var open = nav.classList.toggle('open');
          btn.setAttribute('aria-expanded', open ? 'true' : 'false');
        });
      })();
    </script>

    <!-- ===== 速報クイックアクセスバー ===== -->
    <div class="speed-bar" role="navigation" aria-label="速報ページへのクイックアクセス">
      <div class="speed-bar-inner">
        <div class="sb-section">
          <span class="sb-label npb">⚾ NPB</span>
          <a href="/npb/" class="speed-link"><span class="sl-icon">📊</span><span class="sl-text">順位表</span></a>
          <span class="speed-sep">|</span>
          <a href="/npb/leaders/" class="speed-link"><span class="sl-icon">🏆</span><span class="sl-text">ランキング</span></a>
          <span class="speed-sep">|</span>
          <a href="/npb/results/" class="speed-link"><span class="sl-icon">📋</span><span class="sl-text">試合結果</span></a>
        </div>
        <span class="sb-divider"></span>
        <div class="sb-section">
          <span class="sb-label mlb">🇺🇸 MLB</span>
          <a href="/mlb/standings/" class="speed-link"><span class="sl-icon">📊</span><span class="sl-text">Standings</span></a>
          <span class="speed-sep">|</span>
          <a href="/mlb/leaders/" class="speed-link"><span class="sl-icon">🏆</span><span class="sl-text">Leaders</span></a>
          <span class="speed-sep">|</span>
          <a href="/mlb/results/" class="speed-link"><span class="sl-icon">📋</span><span class="sl-text">Results</span></a>
        </div>
      </div>
    </div>

    <!-- ===== ページコンテンツ ===== -->
    <slot />

    <!-- ===== FOOTER ===== -->
    <footer class="site-footer">
      {isEn ? (
        <div class="footer-links">
          <div class="footer-col">
            <p class="footer-col-title">Stats Guide</p>
            <nav class="footer-col-nav">
              <a href="/en/glossary/">What is Sabermetrics?</a>
              <a href="/en/glossary/">WAR</a>
              <a href="/en/glossary/">OPS</a>
              <a href="/en/glossary/">FIP</a>
              <a href="/en/glossary/">All Stats →</a>
            </nav>
          </div>
          <div class="footer-col">
            <p class="footer-col-title">MLB</p>
            <nav class="footer-col-nav">
              <a href="/en/mlb/">MLB Data</a>
              <a href="/en/mlb/leaders/">MLB Leaders</a>
              <a href="/en/mlb/standings/">Standings</a>
              <a href="/en/mlb/trends/">Trends</a>
              <a href="/en/mlb/analysis/">Analysis</a>
            </nav>
          </div>
          <div class="footer-col">
            <p class="footer-col-title">NPB</p>
            <nav class="footer-col-nav">
              <a href="/en/npb/">NPB Data</a>
              <a href="/en/npb/leaders/">NPB Leaders</a>
              <a href="/en/npb/standings/">Standings</a>
              <a href="/en/npb/trends/">Trends</a>
              <a href="/en/npb/results/">Results</a>
            </nav>
          </div>
          <div class="footer-col">
            <p class="footer-col-title">Players</p>
            <nav class="footer-col-nav">
              <a href="/en/players/">MLB Players</a>
              <a href="/en/teams/">MLB Teams</a>
              <a href="/en/players/shohei-ohtani/">Shohei Ohtani</a>
              <a href="/en/players/yoshinobu-yamamoto/">Yoshinobu Yamamoto</a>
            </nav>
          </div>
        </div>
      ) : (
        <div class="footer-links">
          <div class="footer-col">
            <p class="footer-col-title">指標解説</p>
            <nav class="footer-col-nav">
              <a href="/glossary/sabermetrics/">セイバーメトリクスとは</a>
              <a href="/glossary/war/">WAR</a>
              <a href="/glossary/ops/">OPS</a>
              <a href="/glossary/fip/">FIP</a>
              <a href="/glossary/woba/">wOBA</a>
              <a href="/glossary/">すべての指標 →</a>
            </nav>
          </div>
          <div class="footer-col">
            <p class="footer-col-title">打撃指標</p>
            <nav class="footer-col-nav">
              <a href="/glossary/avg/">打率（AVG）</a>
              <a href="/glossary/obp/">出塁率（OBP）</a>
              <a href="/glossary/slg/">長打率（SLG）</a>
              <a href="/glossary/wrc-plus/">wRC+</a>
              <a href="/glossary/babip/">BABIP</a>
            </nav>
          </div>
          <div class="footer-col">
            <p class="footer-col-title">投球指標</p>
            <nav class="footer-col-nav">
              <a href="/glossary/era/">防御率（ERA）</a>
              <a href="/glossary/whip/">WHIP</a>
              <a href="/glossary/k9/">K/9</a>
              <a href="/glossary/xfip/">xFIP</a>
              <a href="/glossary/siera/">SIERA</a>
            </nav>
          </div>
          <div class="footer-col">
            <p class="footer-col-title">データ</p>
            <nav class="footer-col-nav">
              <a href="/mlb/">MLB データ</a>
              <a href="/mlb/leaders/">MLB ランキング</a>
              <a href="/npb/">NPB データ</a>
              <a href="/players/">MLB 選手一覧</a>
              <a href="/teams/">チーム一覧</a>
              <a href="/search/">サイト内検索</a>
            </nav>
          </div>
        </div>
      )}
      <nav class="footer-nav" aria-label={isEn ? 'Footer navigation' : 'フッターナビゲーション'}>
        <a href="/privacy/">{isEn ? 'Privacy Policy' : 'プライバシーポリシー'}</a>
        <a href="/disclaimer/">{isEn ? 'Disclaimer' : '免責事項'}</a>
        <a href="/disclosure/">{isEn ? 'Advertising' : '広告について'}</a>
      </nav>
      <p class="footer-copy">&copy; 2026 Baseballab. All rights reserved.</p>
    </footer>

  </body>
</html>
